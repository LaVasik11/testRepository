[
  {
    "id": 37412,
    "date": "2025-07-18 19:50:23+00:00",
    "sender_name": "oppionme",
    "text": "Я хочу прощупать тебя изнутри"
  },
  {
    "id": 37409,
    "date": "2025-07-18 19:49:57+00:00",
    "sender_name": "GeorgeKan",
    "text": "Нет, он просто слегка намекнул"
  },
  {
    "id": 37406,
    "date": "2025-07-18 19:48:56+00:00",
    "sender_name": "oppionme",
    "text": "Бля вот бы трахнуть щуплого Тимофея в его анальное отверстие в позе \"миссионерская\" что бы я мог видеть свой невероятный член через его область живота"
  },
  {
    "id": 37403,
    "date": "2025-07-18 19:47:06+00:00",
    "sender_name": "oppionme",
    "text": "Жора он хочет пощекотать твои внутренности напрямую"
  },
  {
    "id": 37401,
    "date": "2025-07-18 19:46:43+00:00",
    "sender_name": "GeorgeKan",
    "text": "Я за"
  },
  {
    "id": 37400,
    "date": "2025-07-18 19:46:42+00:00",
    "sender_name": "GeorgeKan",
    "text": "А так давай"
  },
  {
    "id": 37394,
    "date": "2025-07-18 19:46:05+00:00",
    "sender_name": "GeorgeKan",
    "text": "Объясни поп роще"
  },
  {
    "id": 37393,
    "date": "2025-07-18 19:46:01+00:00",
    "sender_name": "GeorgeKan",
    "text": "Ничего не понял"
  },
  {
    "id": 37392,
    "date": "2025-07-18 19:46:01+00:00",
    "sender_name": "oppionme",
    "text": "Тимофей римминг мастер"
  },
  {
    "id": 37391,
    "date": "2025-07-18 19:45:58+00:00",
    "sender_name": "GeorgeKan",
    "text": "КАк то ты намудрил с тектом"
  },
  {
    "id": 37390,
    "date": "2025-07-18 19:45:51+00:00",
    "sender_name": "GeorgeKan",
    "text": "Не понимаю о чем ты"
  },
  {
    "id": 37386,
    "date": "2025-07-18 19:45:38+00:00",
    "sender_name": "oppionme",
    "text": "Язык походу"
  },
  {
    "id": 37383,
    "date": "2025-07-18 19:45:15+00:00",
    "sender_name": "GeorgeKan",
    "text": "Откуда у меня дрогоцености"
  },
  {
    "id": 37382,
    "date": "2025-07-18 19:45:10+00:00",
    "sender_name": "GeorgeKan",
    "text": "Я бедный студентик"
  },
  {
    "id": 37381,
    "date": "2025-07-18 19:44:51+00:00",
    "sender_name": "oppionme",
    "text": "Жора он хочет осмотреть твои драгоценности поближе"
  },
  {
    "id": 37380,
    "date": "2025-07-18 19:43:36+00:00",
    "sender_name": "GeorgeKan",
    "text": "Тебе то зачес напрягатся"
  },
  {
    "id": 37379,
    "date": "2025-07-18 19:43:31+00:00",
    "sender_name": "GeorgeKan",
    "text": "Я думаю этим сантехник займется"
  },
  {
    "id": 37378,
    "date": "2025-07-18 19:43:19+00:00",
    "sender_name": "GeorgeKan",
    "text": "Я не голоден"
  },
  {
    "id": 37377,
    "date": "2025-07-18 19:43:07+00:00",
    "sender_name": "oppionme",
    "text": "Жора он хочет открыть твой зиплок и оставить там теплое"
  },
  {
    "id": 37376,
    "date": "2025-07-18 19:43:05+00:00",
    "sender_name": "GeorgeKan",
    "text": "И неужели нет места понадежнее чем карман"
  },
  {
    "id": 37374,
    "date": "2025-07-18 19:42:54+00:00",
    "sender_name": "GeorgeKan",
    "text": "Да и откуда у тебя ракета"
  },
  {
    "id": 37373,
    "date": "2025-07-18 19:42:46+00:00",
    "sender_name": "GeorgeKan",
    "text": "Как ракета поместится в карман"
  },
  {
    "id": 37371,
    "date": "2025-07-18 19:42:25+00:00",
    "sender_name": "GeorgeKan",
    "text": "Да и думаю рыбы были бы против"
  },
  {
    "id": 37370,
    "date": "2025-07-18 19:42:20+00:00",
    "sender_name": "GeorgeKan",
    "text": "Но у меня нет такого"
  },
  {
    "id": 37369,
    "date": "2025-07-18 19:42:12+00:00",
    "sender_name": "GeorgeKan",
    "text": "Это же какой аквариум должен быть большой"
  },
  {
    "id": 37368,
    "date": "2025-07-18 19:42:04+00:00",
    "sender_name": "GeorgeKan",
    "text": "Плавать в аквариуме?"
  },
  {
    "id": 37367,
    "date": "2025-07-18 19:41:07+00:00",
    "sender_name": "oppionme",
    "text": "Он вероятно хотел бы поплавать в твоем аквариуме"
  },
  {
    "id": 37366,
    "date": "2025-07-18 19:40:51+00:00",
    "sender_name": "GeorgeKan",
    "text": "Нету шоколадници"
  },
  {
    "id": 37365,
    "date": "2025-07-18 19:40:31+00:00",
    "sender_name": "GeorgeKan",
    "text": "У меня из посуды только пару тарелок"
  },
  {
    "id": 37364,
    "date": "2025-07-18 19:39:56+00:00",
    "sender_name": "oppionme",
    "text": "жора он хочет помешать шоколад в твоей шоколаднице"
  },
  {
    "id": 37363,
    "date": "2025-07-18 19:39:38+00:00",
    "sender_name": "GeorgeKan",
    "text": "Я что вилли вонка по твоему"
  },
  {
    "id": 37362,
    "date": "2025-07-18 19:39:31+00:00",
    "sender_name": "GeorgeKan",
    "text": "Откуда у меня фабрика"
  },
  {
    "id": 37361,
    "date": "2025-07-18 19:39:25+00:00",
    "sender_name": "GeorgeKan",
    "text": "Я думаю тебя оьманывают"
  },
  {
    "id": 37360,
    "date": "2025-07-18 19:39:20+00:00",
    "sender_name": "GeorgeKan",
    "text": "Откуда у тебя эта инфармация"
  },
  {
    "id": 37358,
    "date": "2025-07-18 19:38:46+00:00",
    "sender_name": "GeorgeKan",
    "text": "Постоянно что то мешается на руке"
  },
  {
    "id": 37357,
    "date": "2025-07-18 19:38:39+00:00",
    "sender_name": "GeorgeKan",
    "text": "Думаю это не удобно"
  },
  {
    "id": 37356,
    "date": "2025-07-18 19:38:31+00:00",
    "sender_name": "GeorgeKan",
    "text": "Не ношу кольца"
  },
  {
    "id": 37355,
    "date": "2025-07-18 19:38:21+00:00",
    "sender_name": "oppionme",
    "text": "он хочет ощутить тепло твоего золотого кольца"
  },
  {
    "id": 37354,
    "date": "2025-07-18 19:38:01+00:00",
    "sender_name": "oppionme",
    "text": "жора"
  },
  {
    "id": 37353,
    "date": "2025-07-18 19:36:44+00:00",
    "sender_name": "GeorgeKan",
    "text": "Футбол для быдла"
  },
  {
    "id": 37352,
    "date": "2025-07-18 19:36:35+00:00",
    "sender_name": "GeorgeKan",
    "text": "Вот что что а футбол точно терпеть не могу"
  },
  {
    "id": 37349,
    "date": "2025-07-18 19:34:50+00:00",
    "sender_name": "GeorgeKan",
    "text": "Домашние они"
  },
  {
    "id": 37348,
    "date": "2025-07-18 19:34:46+00:00",
    "sender_name": "GeorgeKan",
    "text": "Мои все собаки в квартире живут"
  },
  {
    "id": 37347,
    "date": "2025-07-18 19:34:38+00:00",
    "sender_name": "GeorgeKan",
    "text": "Откуда канура у меня"
  },
  {
    "id": 37346,
    "date": "2025-07-18 19:34:11+00:00",
    "sender_name": "oppionme",
    "text": "тимофей хочет погавкать своим бобиком в твою конуру"
  },
  {
    "id": 37345,
    "date": "2025-07-18 19:34:01+00:00",
    "sender_name": "oppionme",
    "text": "жора"
  },
  {
    "id": 37344,
    "date": "2025-07-18 19:25:25+00:00",
    "sender_name": "GeorgeKan",
    "text": "Странная игра"
  },
  {
    "id": 37343,
    "date": "2025-07-18 19:25:21+00:00",
    "sender_name": "GeorgeKan",
    "text": "Типо как собаке"
  },
  {
    "id": 37342,
    "date": "2025-07-18 19:25:18+00:00",
    "sender_name": "GeorgeKan",
    "text": "Да и зачем"
  },
  {
    "id": 37341,
    "date": "2025-07-18 19:25:15+00:00",
    "sender_name": "GeorgeKan",
    "text": "А ты с россии до еревана то добросишь?"
  },
  {
    "id": 37338,
    "date": "2025-07-18 19:24:15+00:00",
    "sender_name": "GeorgeKan",
    "text": "Лучше пускай у себя в терариуме сбросит кожу"
  },
  {
    "id": 37337,
    "date": "2025-07-18 19:23:59+00:00",
    "sender_name": "GeorgeKan",
    "text": "Думаю не стоит"
  },
  {
    "id": 37336,
    "date": "2025-07-18 19:23:56+00:00",
    "sender_name": "GeorgeKan",
    "text": "Не люблю змей"
  },
  {
    "id": 37332,
    "date": "2025-07-18 19:22:39+00:00",
    "sender_name": "GeorgeKan",
    "text": "Пока не планирую проходить осмотр"
  },
  {
    "id": 37331,
    "date": "2025-07-18 19:22:32+00:00",
    "sender_name": "GeorgeKan",
    "text": "Я думаю я вполне здоров"
  },
  {
    "id": 37328,
    "date": "2025-07-18 19:21:32+00:00",
    "sender_name": "GeorgeKan",
    "text": "За мир"
  },
  {
    "id": 37327,
    "date": "2025-07-18 19:21:31+00:00",
    "sender_name": "GeorgeKan",
    "text": "Я против войны"
  },
  {
    "id": 37325,
    "date": "2025-07-18 19:20:52+00:00",
    "sender_name": "GeorgeKan",
    "text": "Не видел таких"
  },
  {
    "id": 37324,
    "date": "2025-07-18 19:20:49+00:00",
    "sender_name": "GeorgeKan",
    "text": "Он типо из меха?"
  },
  {
    "id": 37323,
    "date": "2025-07-18 19:20:45+00:00",
    "sender_name": "GeorgeKan",
    "text": "Да и мохнатый сейф звучит странно"
  },
  {
    "id": 37322,
    "date": "2025-07-18 19:20:37+00:00",
    "sender_name": "GeorgeKan",
    "text": "У меня нет сейфа"
  },
  {
    "id": 37319,
    "date": "2025-07-18 19:19:54+00:00",
    "sender_name": "GeorgeKan",
    "text": "Да и врядли у меня такие сокровища что они поплывут с самали до меня"
  },
  {
    "id": 37318,
    "date": "2025-07-18 19:19:36+00:00",
    "sender_name": "GeorgeKan",
    "text": "Пираты же только на самоли остались"
  },
  {
    "id": 37311,
    "date": "2025-07-18 19:18:55+00:00",
    "sender_name": "GeorgeKan",
    "text": "Но у меня нету норки"
  },
  {
    "id": 37310,
    "date": "2025-07-18 19:18:51+00:00",
    "sender_name": "GeorgeKan",
    "text": "Норка это животное такое?"
  },
  {
    "id": 37309,
    "date": "2025-07-18 19:18:20+00:00",
    "sender_name": "GeorgeKan",
    "text": "Да и не понимаю что за норка"
  },
  {
    "id": 37308,
    "date": "2025-07-18 19:18:14+00:00",
    "sender_name": "GeorgeKan",
    "text": "Путешествия"
  },
  {
    "id": 37307,
    "date": "2025-07-18 19:18:10+00:00",
    "sender_name": "GeorgeKan",
    "text": "Собаки не очень переносят"
  },
  {
    "id": 37306,
    "date": "2025-07-18 19:18:06+00:00",
    "sender_name": "GeorgeKan",
    "text": "Я думаю что собаке не очень будет такое растояние преодолеть"
  },
  {
    "id": 37301,
    "date": "2025-07-18 19:16:53+00:00",
    "sender_name": "GeorgeKan",
    "text": "Я не понимаю что ты хочешь"
  },
  {
    "id": 37300,
    "date": "2025-07-18 19:16:47+00:00",
    "sender_name": "GeorgeKan",
    "text": "Ну так объясни ты"
  },
  {
    "id": 37298,
    "date": "2025-07-18 19:16:10+00:00",
    "sender_name": "GeorgeKan",
    "text": "Не очень игра"
  },
  {
    "id": 37297,
    "date": "2025-07-18 19:16:07+00:00",
    "sender_name": "GeorgeKan",
    "text": "Скучно будто бы"
  },
  {
    "id": 37296,
    "date": "2025-07-18 19:16:02+00:00",
    "sender_name": "GeorgeKan",
    "text": "Я не разу в бильярд не играл"
  },
  {
    "id": 37294,
    "date": "2025-07-18 19:15:46+00:00",
    "sender_name": "oppionme",
    "text": "понимаешь ли"
  },
  {
    "id": 37293,
    "date": "2025-07-18 19:15:44+00:00",
    "sender_name": "oppionme",
    "text": "он хочет забить кий в твою лунку"
  },
  {
    "id": 37292,
    "date": "2025-07-18 19:15:44+00:00",
    "sender_name": "GeorgeKan",
    "text": "А"
  },
  {
    "id": 37291,
    "date": "2025-07-18 19:15:40+00:00",
    "sender_name": "oppionme",
    "text": "жора"
  },
  {
    "id": 37290,
    "date": "2025-07-18 19:15:12+00:00",
    "sender_name": "oppionme",
    "text": "апо"
  },
  {
    "id": 37288,
    "date": "2025-07-18 19:14:34+00:00",
    "sender_name": "GeorgeKan",
    "text": "Вредно для здоровья"
  },
  {
    "id": 37287,
    "date": "2025-07-18 19:14:28+00:00",
    "sender_name": "GeorgeKan",
    "text": "Не курю"
  },
  {
    "id": 37285,
    "date": "2025-07-18 19:14:09+00:00",
    "sender_name": "GeorgeKan",
    "text": "А не из кожи"
  },
  {
    "id": 37284,
    "date": "2025-07-18 19:14:06+00:00",
    "sender_name": "GeorgeKan",
    "text": "Да и первый меч из дерева"
  },
  {
    "id": 37283,
    "date": "2025-07-18 19:13:55+00:00",
    "sender_name": "GeorgeKan",
    "text": "Я не смогу скачать майн на линукс"
  },
  {
    "id": 37282,
    "date": "2025-07-18 19:13:43+00:00",
    "sender_name": "GeorgeKan",
    "text": "Ты на дуель в майнкрафте меня вызываешь?"
  },
  {
    "id": 37277,
    "date": "2025-07-18 19:13:02+00:00",
    "sender_name": "GeorgeKan",
    "text": "Не думаю что у меня не хватка белка"
  },
  {
    "id": 37276,
    "date": "2025-07-18 19:12:53+00:00",
    "sender_name": "GeorgeKan",
    "text": "Хаваю че попало"
  },
  {
    "id": 37275,
    "date": "2025-07-18 19:12:47+00:00",
    "sender_name": "GeorgeKan",
    "text": "Не интересуюсь таким"
  },
  {
    "id": 37274,
    "date": "2025-07-18 19:12:41+00:00",
    "sender_name": "GeorgeKan",
    "text": "Я не особо слежу за белками жирами и углеводами"
  },
  {
    "id": 37273,
    "date": "2025-07-18 19:12:32+00:00",
    "sender_name": "GeorgeKan",
    "text": "Не понимаю про что ты"
  },
  {
    "id": 37270,
    "date": "2025-07-18 19:11:56+00:00",
    "sender_name": "GeorgeKan",
    "text": "Не люблю машины"
  },
  {
    "id": 37269,
    "date": "2025-07-18 19:11:50+00:00",
    "sender_name": "GeorgeKan",
    "text": "У меня нет машины"
  },
  {
    "id": 37264,
    "date": "2025-07-18 19:10:07+00:00",
    "sender_name": "GeorgeKan",
    "text": "Я же правильно тебя понял?"
  },
  {
    "id": 37263,
    "date": "2025-07-18 19:09:59+00:00",
    "sender_name": "GeorgeKan",
    "text": "Да и красить чердак белкой краской не лучшая идея"
  },
  {
    "id": 37262,
    "date": "2025-07-18 19:09:19+00:00",
    "sender_name": "GeorgeKan",
    "text": "Тут нету чердака"
  },
  {
    "id": 37261,
    "date": "2025-07-18 19:09:16+00:00",
    "sender_name": "GeorgeKan",
    "text": "Я в общежитии жеву"
  },
  {
    "id": 37260,
    "date": "2025-07-18 19:09:12+00:00",
    "sender_name": "GeorgeKan",
    "text": "Непонимаб о чем ты"
  },
  {
    "id": 37256,
    "date": "2025-07-18 19:06:54+00:00",
    "sender_name": "GeorgeKan",
    "text": "Ну для красоты"
  },
  {
    "id": 37255,
    "date": "2025-07-18 19:06:41+00:00",
    "sender_name": "GeorgeKan",
    "text": "Цветной краской"
  },
  {
    "id": 37253,
    "date": "2025-07-18 19:06:34+00:00",
    "sender_name": "GeorgeKan",
    "text": "1 к 1 маштабом"
  },
  {
    "id": 37252,
    "date": "2025-07-18 19:06:16+00:00",
    "sender_name": "GeorgeKan",
    "text": "Я на члене фото твоей мамы набью"
  },
  {
    "id": 37250,
    "date": "2025-07-18 19:06:05+00:00",
    "sender_name": "GeorgeKan",
    "text": "Уёбок ты"
  },
  {
    "id": 37249,
    "date": "2025-07-18 19:06:03+00:00",
    "sender_name": "GeorgeKan",
    "text": "Сука"
  },
  {
    "id": 37245,
    "date": "2025-07-18 19:05:54+00:00",
    "sender_name": "GeorgeKan",
    "text": "О блядскую слезу под глазом"
  },
  {
    "id": 37243,
    "date": "2025-07-18 19:05:52+00:00",
    "sender_name": "oppionme",
    "text": "элден ринг"
  },
  {
    "id": 37241,
    "date": "2025-07-18 19:05:50+00:00",
    "sender_name": "oppionme",
    "text": "типо хоара лу"
  },
  {
    "id": 37240,
    "date": "2025-07-18 19:05:40+00:00",
    "sender_name": "GeorgeKan",
    "text": "Не варик"
  },
  {
    "id": 37239,
    "date": "2025-07-18 19:05:37+00:00",
    "sender_name": "GeorgeKan",
    "text": "Купола будет перекрывать"
  },
  {
    "id": 37236,
    "date": "2025-07-18 19:04:20+00:00",
    "sender_name": "oppionme",
    "text": "венец иисуса вокруг зоны бикини"
  },
  {
    "id": 37235,
    "date": "2025-07-18 19:04:15+00:00",
    "sender_name": "GeorgeKan",
    "text": "На груди"
  },
  {
    "id": 37234,
