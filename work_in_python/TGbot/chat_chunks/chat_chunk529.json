[
  {
    "id": 66859,
    "date": "2025-09-02 17:22:22+00:00",
    "sender_name": "gaysesg",
    "text": "Жмакал"
  },
  {
    "id": 66858,
    "date": "2025-09-02 17:22:21+00:00",
    "sender_name": "oppionme",
    "text": "сори"
  },
  {
    "id": 66857,
    "date": "2025-09-02 17:22:20+00:00",
    "sender_name": "gaysesg",
    "text": "Ты их трогал?"
  },
  {
    "id": 66856,
    "date": "2025-09-02 17:22:15+00:00",
    "sender_name": "GeorgeKan",
    "text": "Обоих"
  },
  {
    "id": 66855,
    "date": "2025-09-02 17:22:13+00:00",
    "sender_name": "GeorgeKan",
    "text": "Рак яичек"
  },
  {
    "id": 66854,
    "date": "2025-09-02 17:22:06+00:00",
    "sender_name": "GeorgeKan",
    "text": "Больно крепко ты спишь"
  },
  {
    "id": 66853,
    "date": "2025-09-02 17:22:03+00:00",
    "sender_name": "gaysesg",
    "text": "Да"
  },
  {
    "id": 66852,
    "date": "2025-09-02 17:22:01+00:00",
    "sender_name": "GeorgeKan",
    "text": "А я проверил"
  },
  {
    "id": 66851,
    "date": "2025-09-02 17:21:58+00:00",
    "sender_name": "GeorgeKan",
    "text": "Это дар божий?"
  },
  {
    "id": 66850,
    "date": "2025-09-02 17:21:54+00:00",
    "sender_name": "gaysesg",
    "text": "Ты проверь"
  },
  {
    "id": 66849,
    "date": "2025-09-02 17:21:49+00:00",
    "sender_name": "GeorgeKan",
    "text": "Проверь"
  },
  {
    "id": 66848,
    "date": "2025-09-02 17:21:49+00:00",
    "sender_name": "gaysesg",
    "text": "И это не проблема"
  },
  {
    "id": 66847,
    "date": "2025-09-02 17:21:48+00:00",
    "sender_name": "GeorgeKan",
    "text": "Правда"
  },
  {
    "id": 66846,
    "date": "2025-09-02 17:21:44+00:00",
    "sender_name": "gaysesg",
    "text": "Неправда"
  },
  {
    "id": 66845,
    "date": "2025-09-02 17:21:40+00:00",
    "sender_name": "GeorgeKan",
    "text": "У тебя рак яичек"
  },
  {
    "id": 66844,
    "date": "2025-09-02 17:21:34+00:00",
    "sender_name": "gaysesg",
    "text": "У меня нет проблем"
  },
  {
    "id": 66843,
    "date": "2025-09-02 17:21:32+00:00",
    "sender_name": "GeorgeKan",
    "text": "И пиздят что им хавать нехуй"
  },
  {
    "id": 66842,
    "date": "2025-09-02 17:21:30+00:00",
    "sender_name": "gaysesg",
    "text": "С каких наших"
  },
  {
    "id": 66841,
    "date": "2025-09-02 17:21:20+00:00",
    "sender_name": "GeorgeKan",
    "text": "И полки"
  },
  {
    "id": 66840,
    "date": "2025-09-02 17:21:17+00:00",
    "sender_name": "GeorgeKan",
    "text": "В которой есть холодильник"
  },
  {
    "id": 66839,
    "date": "2025-09-02 17:21:11+00:00",
    "sender_name": "GeorgeKan",
    "text": "Челы живут в квартире"
  },
  {
    "id": 66838,
    "date": "2025-09-02 17:21:06+00:00",
    "sender_name": "GeorgeKan",
    "text": "Я хуею с ваших проблем"
  },
  {
    "id": 66837,
    "date": "2025-09-02 17:18:18+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "хоть сиди специи хавай просто так"
  },
  {
    "id": 66836,
    "date": "2025-09-02 17:18:15+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "нихуя нет"
  },
  {
    "id": 66835,
    "date": "2025-09-02 17:18:14+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "ни дошика"
  },
  {
    "id": 66834,
    "date": "2025-09-02 17:18:10+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "да нет нихуя дома"
  },
  {
    "id": 66833,
    "date": "2025-09-02 17:18:08+00:00",
    "sender_name": "oppionme",
    "text": "авсяную"
  },
  {
    "id": 66832,
    "date": "2025-09-02 17:18:06+00:00",
    "sender_name": "oppionme",
    "text": "кашку"
  },
  {
    "id": 66831,
    "date": "2025-09-02 17:18:04+00:00",
    "sender_name": "oppionme",
    "text": "=)"
  },
  {
    "id": 66830,
    "date": "2025-09-02 17:18:02+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "ПРОСТО НЕЧЕГО СВАРИТЬ"
  },
  {
    "id": 66829,
    "date": "2025-09-02 17:18:00+00:00",
    "sender_name": "oppionme",
    "text": "квас"
  },
  {
    "id": 66828,
    "date": "2025-09-02 17:17:59+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "вообще блять"
  },
  {
    "id": 66827,
    "date": "2025-09-02 17:17:56+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "жрать нечего"
  },
  {
    "id": 66826,
    "date": "2025-09-02 17:16:09+00:00",
    "sender_name": "gaysesg",
    "text": "Кола в стакане зеро?"
  },
  {
    "id": 66823,
    "date": "2025-09-02 16:28:36+00:00",
    "sender_name": "oppionme",
    "text": "на пп"
  },
  {
    "id": 66821,
    "date": "2025-09-02 16:27:47+00:00",
    "sender_name": "oppionme",
    "text": "СТОП"
  },
  {
    "id": 66820,
    "date": "2025-09-02 16:27:47+00:00",
    "sender_name": "oppionme",
    "text": "В КАКОЙ"
  },
  {
    "id": 66815,
    "date": "2025-09-02 15:38:17+00:00",
    "sender_name": "oppionme",
    "text": "сегодня ты в прайме"
  },
  {
    "id": 66814,
    "date": "2025-09-02 15:37:35+00:00",
    "sender_name": "GeorgeKan",
    "text": "Я мейби бейби"
  },
  {
    "id": 66813,
    "date": "2025-09-02 15:37:24+00:00",
    "sender_name": "oppionme",
    "text": "спасибо Дора"
  },
  {
    "id": 66812,
    "date": "2025-09-02 15:37:16+00:00",
    "sender_name": "GeorgeKan",
    "text": "Не оглядываясь"
  },
  {
    "id": 66811,
    "date": "2025-09-02 15:37:09+00:00",
    "sender_name": "GeorgeKan",
    "text": "На уверенном подошёл снял клад и пошёл дальше"
  },
  {
    "id": 66810,
    "date": "2025-09-02 15:36:52+00:00",
    "sender_name": "GeorgeKan",
    "text": "Ты можешь так не оглядываться когда клад снимаешь. Это наабарот больше внимания привлекает"
  },
  {
    "id": 66808,
    "date": "2025-09-02 13:54:02+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "скоро трусы уже снимите"
  },
  {
    "id": 66807,
    "date": "2025-09-02 13:54:00+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "до трусов"
  },
  {
    "id": 66806,
    "date": "2025-09-02 13:53:59+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "раздеваетесь да"
  },
  {
    "id": 66805,
    "date": "2025-09-02 13:53:12+00:00",
    "sender_name": "oppionme",
    "text": "потные мужчины нам в зале всем жарко"
  },
  {
    "id": 66804,
    "date": "2025-09-02 13:53:04+00:00",
    "sender_name": "oppionme",
    "text": "в зал"
  },
  {
    "id": 66803,
    "date": "2025-09-02 13:53:03+00:00",
    "sender_name": "oppionme",
    "text": "прибежала толпа"
  },
  {
    "id": 66802,
    "date": "2025-09-02 13:53:00+00:00",
    "sender_name": "oppionme",
    "text": "после шарагм"
  },
  {
    "id": 66801,
    "date": "2025-09-02 13:52:58+00:00",
    "sender_name": "oppionme",
    "text": "бля пизедц"
  },
  {
    "id": 66798,
    "date": "2025-09-02 13:38:26+00:00",
    "sender_name": "gaysesg",
    "text": "у него фрапса нету"
  },
  {
    "id": 66797,
    "date": "2025-09-02 13:38:12+00:00",
    "sender_name": "GeorgeKan",
    "text": "Так он жб накатает"
  },
  {
    "id": 66796,
    "date": "2025-09-02 13:38:02+00:00",
    "sender_name": "gaysesg",
    "text": "на 5 вито холиджеймс"
  },
  {
    "id": 66795,
    "date": "2025-09-02 13:37:54+00:00",
    "sender_name": "gaysesg",
    "text": "4"
  },
  {
    "id": 66794,
    "date": "2025-09-02 13:37:47+00:00",
    "sender_name": "GeorgeKan",
    "text": "Все 5 раз?"
  },
  {
    "id": 66793,
    "date": "2025-09-02 13:37:38+00:00",
    "sender_name": "gaysesg",
    "text": "обаму"
  },
  {
    "id": 66792,
    "date": "2025-09-02 13:37:29+00:00",
    "sender_name": "GeorgeKan",
    "text": "Топ 5 людей кого бы нежданул"
  },
  {
    "id": 66791,
    "date": "2025-09-02 13:37:22+00:00",
    "sender_name": "gaysesg",
    "text": "жора ты неждун"
  },
  {
    "id": 66790,
    "date": "2025-09-02 13:37:13+00:00",
    "sender_name": "GeorgeKan",
    "text": "Неждануть"
  },
  {
    "id": 66789,
    "date": "2025-09-02 13:37:11+00:00",
    "sender_name": "GeorgeKan",
    "text": "Самое тупое слово"
  },
  {
    "id": 66788,
    "date": "2025-09-02 13:37:08+00:00",
    "sender_name": "gaysesg",
    "text": "по дружески"
  },
  {
    "id": 66787,
    "date": "2025-09-02 13:37:07+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Без негатива"
  },
  {
    "id": 66786,
    "date": "2025-09-02 13:37:03+00:00",
    "sender_name": "gaysesg",
    "text": "без негатива?"
  },
  {
    "id": 66785,
    "date": "2025-09-02 13:36:49+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Бля ну не знаю если бы Миха рядом сидел я бы ему нежданул"
  },
  {
    "id": 66784,
    "date": "2025-09-02 13:36:47+00:00",
    "sender_name": "GeorgeKan",
    "text": "Ниждануть так сказать"
  },
  {
    "id": 66783,
    "date": "2025-09-02 13:36:38+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Можно отказаться"
  },
  {
    "id": 66782,
    "date": "2025-09-02 13:36:36+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Подумай о последствиях"
  },
  {
    "id": 66781,
    "date": "2025-09-02 13:36:36+00:00",
    "sender_name": "gaysesg",
    "text": "а можно на неожиданичах мише въебать"
  },
  {
    "id": 66780,
    "date": "2025-09-02 13:36:35+00:00",
    "sender_name": "GeorgeKan",
    "text": "Не норм"
  },
  {
    "id": 66779,
    "date": "2025-09-02 13:36:32+00:00",
    "sender_name": "GeorgeKan",
    "text": "А я че"
  },
  {
    "id": 66778,
    "date": "2025-09-02 13:36:25+00:00",
    "sender_name": "gaysesg",
    "text": "миша норм"
  },
  {
    "id": 66777,
    "date": "2025-09-02 13:36:21+00:00",
    "sender_name": "GeorgeKan",
    "text": "А мише"
  },
  {
    "id": 66776,
    "date": "2025-09-02 13:36:14+00:00",
    "sender_name": "gaysesg",
    "text": "выбор из тебя и жоры"
  },
  {
    "id": 66775,
    "date": "2025-09-02 13:35:58+00:00",
    "sender_name": "gaysesg",
    "text": "точно не сене"
  },
  {
    "id": 66774,
    "date": "2025-09-02 13:35:55+00:00",
    "sender_name": "gaysesg",
    "text": "подумать надо"
  },
  {
    "id": 66773,
    "date": "2025-09-02 13:35:49+00:00",
    "sender_name": "gaysesg",
    "text": "самсунг гелекси м23 и чутьчуть поменьше"
  },
  {
    "id": 66771,
    "date": "2025-09-02 13:35:07+00:00",
    "sender_name": "GeorgeKan",
    "text": "Это вопрос с подвохом?"
  },
  {
    "id": 66770,
    "date": "2025-09-02 13:34:35+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Признавайтесь"
  },
  {
    "id": 66769,
    "date": "2025-09-02 13:34:33+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "У кого сколько см хуй"
  },
  {
    "id": 66768,
    "date": "2025-09-02 13:32:59+00:00",
    "sender_name": "GeorgeKan",
    "text": "Он бы миновал дистанцию между своим челом и губами"
  },
  {
    "id": 66767,
    "date": "2025-09-02 13:32:39+00:00",
    "sender_name": "GeorgeKan",
    "text": "Ну да, тогда ответ был бы слишком очевиден"
  },
  {
    "id": 66766,
    "date": "2025-09-02 13:32:16+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Нет Жора я не буду менять формулировку вопроса на «возможность отсосать»"
  },
  {
    "id": 66765,
    "date": "2025-09-02 13:31:31+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Кому бы ты переебал"
  },
  {
    "id": 66764,
    "date": "2025-09-02 13:31:24+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Никита если бы у тебя была возможность переебать одному из нас в еблище минуя дистанцию между телами"
  },
  {
    "id": 66763,
    "date": "2025-09-02 13:29:32+00:00",
    "sender_name": "gaysesg",
    "text": "в ебучку хрясь"
  },
  {
    "id": 66761,
    "date": "2025-09-02 13:22:52+00:00",
    "sender_name": "oppionme",
    "text": "я ебал жену Обамы"
  },
  {
    "id": 66760,
    "date": "2025-09-02 13:22:47+00:00",
    "sender_name": "GeorgeKan",
    "text": "Надеюсь не заметишь"
  },
  {
    "id": 66759,
    "date": "2025-09-02 13:22:43+00:00",
    "sender_name": "GeorgeKan",
    "text": "Быстро закрою глаза и сделаю вид что не открывал"
  },
  {
    "id": 66758,
    "date": "2025-09-02 13:22:28+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Ваши действия?"
  },
  {
    "id": 66757,
    "date": "2025-09-02 13:22:26+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Вы открыли глаза после утреннего пробуждения и видите это"
  },
  {
    "id": 66756,
    "date": "2025-09-02 13:22:09+00:00",
    "sender_name": "GeorgeKan",
    "text": "Император пту"
  },
  {
    "id": 66753,
    "date": "2025-09-02 13:21:44+00:00",
    "sender_name": "oppionme",
    "text": "кахахэа лашара"
  },
  {
    "id": 66752,
    "date": "2025-09-02 13:21:28+00:00",
    "sender_name": "oppionme",
    "text": "ахаххаа"
  },
  {
    "id": 66751,
    "date": "2025-09-02 13:20:15+00:00",
    "sender_name": "gaysesg",
    "text": "Да"
  },
  {
    "id": 66750,
    "date": "2025-09-02 13:20:07+00:00",
    "sender_name": "GeorgeKan",
    "text": "Дз много задали?"
  },
  {
    "id": 66749,
    "date": "2025-09-02 13:19:51+00:00",
    "sender_name": "gaysesg",
    "text": "Я не пойду в кристаликс"
  },
  {
    "id": 66748,
    "date": "2025-09-02 13:19:30+00:00",
    "sender_name": "gaysesg",
    "text": "И проституткой"
  },
  {
    "id": 66747,
    "date": "2025-09-02 13:19:26+00:00",
    "sender_name": "gaysesg",
    "text": "Шлюхой"
  },
  {
    "id": 66746,
    "date": "2025-09-02 13:19:24+00:00",
    "sender_name": "GeorgeKan",
    "text": "Сильно"
  },
  {
    "id": 66745,
    "date": "2025-09-02 13:19:22+00:00",
    "sender_name": "gaysesg",
    "text": "Тебя называют блядью"
  },
  {
    "id": 66744,
    "date": "2025-09-02 13:19:20+00:00",
    "sender_name": "GeorgeKan",
    "text": "Хм, бесплатно?"
  },
  {
    "id": 66743,
    "date": "2025-09-02 13:19:18+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "@pic школьник"
  },
  {
    "id": 66742,
    "date": "2025-09-02 13:19:12+00:00",
    "sender_name": "GeorgeKan",
    "text": "Порой меня так называют"
  },
  {
    "id": 66741,
    "date": "2025-09-02 13:19:12+00:00",
    "sender_name": "gaysesg",
    "text": "Пососи мой член"
  },
  {
    "id": 66740,
    "date": "2025-09-02 13:19:02+00:00",
    "sender_name": "GeorgeKan",
    "text": "Да это моё имя"
  },
  {
    "id": 66739,
    "date": "2025-09-02 13:18:54+00:00",
    "sender_name": "gaysesg",
    "text": "Жора"
  },
  {
    "id": 66738,
    "date": "2025-09-02 13:18:42+00:00",
    "sender_name": "oppionme",
    "text": "ну извините"
  },
  {
    "id": 66737,
    "date": "2025-09-02 13:18:38+00:00",
    "sender_name": "oppionme",
    "text": "поздно"
  },
  {
    "id": 66736,
    "date": "2025-09-02 13:18:37+00:00",
    "sender_name": "GeorgeKan",
    "text": "У тебя и так бицуха больше чем голова никиты"
  },
  {
    "id": 66734,
    "date": "2025-09-02 13:18:27+00:00",
    "sender_name": "GeorgeKan",
    "text": "1 день"
  },
  {
    "id": 66733,
    "date": "2025-09-02 13:18:25+00:00",
    "sender_name": "GeorgeKan",
    "text": "Пропусти"
  },
  {
    "id": 66732,
    "date": "2025-09-02 13:18:19+00:00",
    "sender_name": "oppionme",
    "text": "я в зал"
  },
  {
    "id": 66731,
