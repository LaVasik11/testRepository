    "id": 96097,
    "date": "2025-10-01 07:26:59+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "#include <stdio.h>\n\nint main() {\n    const char *test_string = \"Hello, World!\";\n    \n    printf(\"Простая хеш: %u\\n\", simple_hash(test_string));\n    printf(\"djb2 хеш: %lu\\n\", djb2_hash(test_string));\n    printf(\"FNV-1a хеш: %u\\n\", fnv1a_hash(test_string, strlen(test_string)));\n    \n    int number = 42;\n    printf(\"Хеш числа: %u\\n\", int_hash(number));\n    \n    return 0;\n}"
  },
  {
    "id": 96096,
    "date": "2025-10-01 07:26:54+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "unsigned int fnv1a_hash(const void *data, size_t size) {\n    const unsigned int FNV_prime = 16777619;\n    const unsigned int FNV_offset_basis = 2166136261;\n    \n    unsigned int hash = FNV_offset_basis;\n    const unsigned char *bytes = (const unsigned char *)data;\n    \n    for (size_t i = 0; i < size; i++) {\n        hash ^= bytes[i];\n        hash *= FNV_prime;\n    }\n    \n    return hash;\n}"
  },
  {
    "id": 96095,
    "date": "2025-10-01 07:26:49+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "unsigned long djb2_hash(const char *str) {\n    unsigned long hash = 5381;\n    int c;\n    \n    while ((c = *str++)) {\n        hash = ((hash << 5) + hash) + c; // hash * 33 + c\n    }\n    \n    return hash;\n}"
  },
  {
    "id": 96094,
    "date": "2025-10-01 07:26:42+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "#include <stdio.h>\n#include <string.h>\n\nunsigned int simple_hash(const char *str) {\n    unsigned int hash = 0;\n    \n    while (*str) {\n        hash = (hash * 31) + *str; // Умножаем на простое число и добавляем символ\n        str++;\n    }\n    \n    return hash;\n}"
  },
