[
  {
    "id": 96534,
    "date": "2025-10-02 16:43:25+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Может скинемся ему на общагу"
  },
  {
    "id": 96533,
    "date": "2025-10-02 16:43:22+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Тебе не жалко Никиту что он бездомный?"
  },
  {
    "id": 96532,
    "date": "2025-10-02 16:43:18+00:00",
    "sender_name": "GeorgeKan",
    "text": "давай"
  },
  {
    "id": 96531,
    "date": "2025-10-02 16:43:08+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Жора а вот серьезный вопрос тебе задам ну душноватый такой"
  },
  {
    "id": 96530,
    "date": "2025-10-02 16:43:08+00:00",
    "sender_name": "GeorgeKan",
    "text": "факт"
  },
  {
    "id": 96529,
    "date": "2025-10-02 16:43:07+00:00",
    "sender_name": "GeorgeKan",
    "text": "просто"
  },
  {
    "id": 96528,
    "date": "2025-10-02 16:43:06+00:00",
    "sender_name": "GeorgeKan",
    "text": "это так"
  },
  {
    "id": 96527,
    "date": "2025-10-02 16:43:05+00:00",
    "sender_name": "GeorgeKan",
    "text": "это никак не связано со словом близницы если что"
  },
  {
    "id": 96526,
    "date": "2025-10-02 16:42:54+00:00",
    "sender_name": "GeorgeKan",
    "text": "однояйцовые"
  },
  {
    "id": 96525,
    "date": "2025-10-02 16:42:51+00:00",
    "sender_name": "GeorgeKan",
    "text": "1 в 1"
  },
  {
    "id": 96524,
    "date": "2025-10-02 16:42:49+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Сиамские"
  },
  {
    "id": 96523,
    "date": "2025-10-02 16:42:43+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Мы же близнецы практически"
  },
  {
    "id": 96522,
    "date": "2025-10-02 16:42:37+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Ну да"
  },
  {
    "id": 96521,
    "date": "2025-10-02 16:42:32+00:00",
    "sender_name": "GeorgeKan",
    "text": "надо только волосы отрастить по длинее"
  },
  {
    "id": 96520,
    "date": "2025-10-02 16:42:21+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Никто бы и не заметил разницы"
  },
  {
    "id": 96519,
    "date": "2025-10-02 16:42:16+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "И ходил бы на работу мою"
  },
  {
    "id": 96518,
    "date": "2025-10-02 16:42:11+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "И стал бы Тимофеем"
  },
  {
    "id": 96517,
    "date": "2025-10-02 16:42:06+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Паспорт"
  },
  {
    "id": 96516,
    "date": "2025-10-02 16:42:04+00:00",
    "sender_name": "GeorgeKan",
    "text": "как в америке делают те кому здают хаты"
  },
  {
    "id": 96515,
    "date": "2025-10-02 16:42:04+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Забрал бы мои инициалы"
  },
  {
    "id": 96514,
    "date": "2025-10-02 16:42:01+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Да"
  },
  {
    "id": 96513,
    "date": "2025-10-02 16:41:58+00:00",
    "sender_name": "GeorgeKan",
    "text": "я бы тебя просто выжал бы из квартиры"
  },
  {
    "id": 96512,
    "date": "2025-10-02 16:41:51+00:00",
    "sender_name": "GeorgeKan",
    "text": "да"
  },
  {
    "id": 96511,
    "date": "2025-10-02 16:41:48+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Чтобы все выжать"
  },
  {
    "id": 96510,
    "date": "2025-10-02 16:41:46+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "И те выбросил"
  },
  {
    "id": 96509,
    "date": "2025-10-02 16:41:44+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "В трусах"
  },
  {
    "id": 96508,
    "date": "2025-10-02 16:41:42+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Ты бы приехал просто"
  },
  {
    "id": 96507,
    "date": "2025-10-02 16:41:40+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Мне кажется ты если бы приехал ты бы мои трусы носил блять и шмотки"
  },
  {
    "id": 96506,
    "date": "2025-10-02 16:41:32+00:00",
    "sender_name": "GeorgeKan",
    "text": "выжал бы все соки"
  },
  {
    "id": 96505,
    "date": "2025-10-02 16:41:29+00:00",
    "sender_name": "GeorgeKan",
    "text": "я если бы приехал"
  },
  {
    "id": 96504,
    "date": "2025-10-02 16:41:26+00:00",
    "sender_name": "GeorgeKan",
    "text": "что обсалютная правда"
  },
  {
    "id": 96503,
    "date": "2025-10-02 16:41:16+00:00",
    "sender_name": "GeorgeKan",
    "text": "ты думаешь я бы принипиально не рубля бы не потратил на еду после приезда к тебе?"
  },
  {
    "id": 96502,
    "date": "2025-10-02 16:40:46+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Думаю это был бы наш обед учитывая моё финансовое состояние"
  },
  {
    "id": 96501,
    "date": "2025-10-02 16:40:38+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "По поводу ситуации"
  },
  {
    "id": 96500,
    "date": "2025-10-02 16:40:34+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Когда такое делает"
  },
  {
    "id": 96499,
    "date": "2025-10-02 16:40:33+00:00",
    "sender_name": "GeorgeKan",
    "text": "а по поводу ситуации что"
  },
  {
    "id": 96498,
    "date": "2025-10-02 16:40:31+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Собака тоже невинный ебало корчит"
  },
  {
    "id": 96497,
    "date": "2025-10-02 16:40:25+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "В говно"
  },
  {
    "id": 96496,
    "date": "2025-10-02 16:40:24+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Я бы тебя носом тыкал"
  },
  {
    "id": 96495,
    "date": "2025-10-02 16:40:07+00:00",
    "sender_name": "GeorgeKan",
    "text": "просто совподение такое"
  },
  {
    "id": 96494,
    "date": "2025-10-02 16:40:03+00:00",
    "sender_name": "GeorgeKan",
    "text": "учитывая что после моего уезда больше не разу не повторилось бы это"
  },
  {
    "id": 96493,
    "date": "2025-10-02 16:39:49+00:00",
    "sender_name": "GeorgeKan",
    "text": "ты бы поверил?"
  },
  {
    "id": 96492,
    "date": "2025-10-02 16:39:46+00:00",
    "sender_name": "GeorgeKan",
    "text": "а я бы утверждал что это был не я"
  },
  {
    "id": 96491,
    "date": "2025-10-02 16:39:40+00:00",
    "sender_name": "GeorgeKan",
    "text": "именно в этот момент"
  },
  {
    "id": 96490,
    "date": "2025-10-02 16:39:36+00:00",
    "sender_name": "GeorgeKan",
    "text": "и кто то бы насрал под дверь"
  },
  {
    "id": 96489,
    "date": "2025-10-02 16:39:32+00:00",
    "sender_name": "GeorgeKan",
    "text": "на пару дней"
  },
  {
    "id": 96488,
    "date": "2025-10-02 16:39:29+00:00",
    "sender_name": "GeorgeKan",
    "text": "пока я был убы у тебя в гостях"
  },
  {
    "id": 96487,
    "date": "2025-10-02 16:39:20+00:00",
    "sender_name": "GeorgeKan",
    "text": "а если бы наабарот"
  },
  {
    "id": 96486,
    "date": "2025-10-02 16:36:55+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "И начал загоняться что ты живешь очень рядом и просто меня преследуешь"
  },
  {
    "id": 96485,
    "date": "2025-10-02 16:36:46+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Я ведь в натуре бы постоянно думал об этом"
  },
  {
    "id": 96484,
    "date": "2025-10-02 16:36:39+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "А ты бы смеялся и рофлил что это ты"
  },
  {
    "id": 96483,
    "date": "2025-10-02 16:36:33+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Вот если бы мне под дверь насрали"
  },
  {
    "id": 96482,
    "date": "2025-10-02 16:36:30+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Не самозванец"
  },
  {
    "id": 96481,
    "date": "2025-10-02 16:36:27+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Не выдуманный"
  },
  {
    "id": 96480,
    "date": "2025-10-02 16:36:26+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "По системе дурки"
  },
  {
    "id": 96479,
    "date": "2025-10-02 16:36:19+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Я же паранойик дохуя"
  },
  {
    "id": 96478,
    "date": "2025-10-02 16:36:17+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Я вот только что задумался"
  },
  {
    "id": 96477,
    "date": "2025-10-02 16:35:41+00:00",
    "sender_name": "GeorgeKan",
    "text": "я"
  },
  {
    "id": 96476,
    "date": "2025-10-02 16:35:40+00:00",
    "sender_name": "GeorgeKan",
    "text": "он бы все ровно говорил бы что не верит в то что это был"
  },
  {
    "id": 96475,
    "date": "2025-10-02 16:35:28+00:00",
    "sender_name": "GeorgeKan",
    "text": "даже если бы не было улсовия про то что он не знал бы кто это сделал"
  },
  {
    "id": 96474,
    "date": "2025-10-02 16:35:16+00:00",
    "sender_name": "GeorgeKan",
    "text": "и никита по любому не поверит"
  },
  {
    "id": 96473,
    "date": "2025-10-02 16:35:10+00:00",
    "sender_name": "GeorgeKan",
    "text": "правда придется доказывать что это сделал именно я"
  },
  {
    "id": 96472,
    "date": "2025-10-02 16:35:04+00:00",
    "sender_name": "GeorgeKan",
    "text": "и полоивну себе забрать"
  },
  {
    "id": 96471,
    "date": "2025-10-02 16:35:00+00:00",
    "sender_name": "GeorgeKan",
    "text": "я просто подумал а вчем проблема если я могу сделат ьвсе что угодно ему заспавнить ему миллион деняг"
  },
  {
    "id": 96470,
    "date": "2025-10-02 16:34:37+00:00",
    "sender_name": "GeorgeKan",
    "text": "именно"
  },
  {
    "id": 96469,
    "date": "2025-10-02 16:34:29+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Я правильно понимаю что на пересадку потребуется только 5 а о том что ты будешь делать 15 минут лучше не спрашивать?"
  },
  {
    "id": 96468,
    "date": "2025-10-02 16:34:28+00:00",
    "sender_name": "GeorgeKan",
    "text": "такое я и без суперсил провернуть могу"
  },
  {
    "id": 96467,
    "date": "2025-10-02 16:34:21+00:00",
    "sender_name": "GeorgeKan",
    "text": "ты меня недооцениваешь"
  },
  {
    "id": 96466,
    "date": "2025-10-02 16:34:10+00:00",
    "sender_name": "GeorgeKan",
    "text": "дайте мне ножницы клей и минут 20 времени"
  },
  {
    "id": 96465,
    "date": "2025-10-02 16:34:01+00:00",
    "sender_name": "GeorgeKan",
    "text": "могу"
  },
  {
    "id": 96464,
    "date": "2025-10-02 16:34:00+00:00",
    "sender_name": "GeorgeKan",
    "text": "схуяли"
  },
  {
    "id": 96463,
    "date": "2025-10-02 16:33:54+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Ты не можешь ему хуй на лоб перенести"
  },
  {
    "id": 96462,
    "date": "2025-10-02 16:33:49+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Ну в рамках реалистичного"
  },
  {
    "id": 96461,
    "date": "2025-10-02 16:33:47+00:00",
    "sender_name": "GeorgeKan",
    "text": "знаешь"
  },
  {
    "id": 96460,
    "date": "2025-10-02 16:33:46+00:00",
    "sender_name": "GeorgeKan",
    "text": "типо суперсилы"
  },
  {
    "id": 96459,
    "date": "2025-10-02 16:33:44+00:00",
    "sender_name": "GeorgeKan",
    "text": "все что возможно"
  },
  {
    "id": 96458,
    "date": "2025-10-02 16:33:41+00:00",
    "sender_name": "GeorgeKan",
    "text": "или все что угодна в плане вообще"
  },
  {
    "id": 96457,
    "date": "2025-10-02 16:33:35+00:00",
    "sender_name": "GeorgeKan",
    "text": "все что угодно что могу сделать я"
  },
  {
    "id": 96456,
    "date": "2025-10-02 16:33:29+00:00",
    "sender_name": "GeorgeKan",
    "text": "типо в каком смысле"
  },
  {
    "id": 96455,
    "date": "2025-10-02 16:33:25+00:00",
    "sender_name": "GeorgeKan",
    "text": "прям что угодно"
  },
  {
    "id": 96454,
    "date": "2025-10-02 16:33:08+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Вот если бы я мог буквально все что угодно"
  },
  {
    "id": 96453,
    "date": "2025-10-02 16:33:02+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Я бы"
  },
  {
    "id": 96452,
    "date": "2025-10-02 16:32:19+00:00",
    "sender_name": "GeorgeKan",
    "text": "жалко только то что он не узнает"
  },
  {
    "id": 96451,
    "date": "2025-10-02 16:32:13+00:00",
    "sender_name": "GeorgeKan",
    "text": "оральный ответ"
  },
  {
    "id": 96450,
    "date": "2025-10-02 16:32:11+00:00",
    "sender_name": "GeorgeKan",
    "text": "банальный вопрос"
  },
  {
    "id": 96449,
    "date": "2025-10-02 16:32:08+00:00",
    "sender_name": "GeorgeKan",
    "text": "ну очевидно отсасал бы"
  },
  {
    "id": 96448,
    "date": "2025-10-02 16:31:57+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "И вал халу"
  },
  {
    "id": 96447,
    "date": "2025-10-02 16:31:55+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Точно"
  },
  {
    "id": 96446,
    "date": "2025-10-02 16:31:54+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Хахахаха"
  },
  {
    "id": 96445,
    "date": "2025-10-02 16:31:50+00:00",
    "sender_name": "GeorgeKan",
    "text": "а зачем бог создал алаха"
  },
  {
    "id": 96444,
    "date": "2025-10-02 16:31:46+00:00",
    "sender_name": "GeorgeKan",
    "text": "ладно у меня появился еще один философфский вопрос"
  },
  {
    "id": 96443,
    "date": "2025-10-02 16:31:43+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Чтобы ты сделал?"
  },
  {
    "id": 96442,
    "date": "2025-10-02 16:31:42+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Жора вот представь что тебе можно что угодно сделать Никите и он не узнает что это был ты и ты не будешь наказан"
  },
  {
    "id": 96441,
    "date": "2025-10-02 16:31:33+00:00",
    "sender_name": "GeorgeKan",
    "text": "и потом брать реванш"
  },
  {
    "id": 96440,
    "date": "2025-10-02 16:31:29+00:00",
    "sender_name": "GeorgeKan",
    "text": "не хотелось бы разбить"
  },
  {
    "id": 96439,
    "date": "2025-10-02 16:31:23+00:00",
    "sender_name": "GeorgeKan",
    "text": "но это максимум"
  },
  {
    "id": 96438,
    "date": "2025-10-02 16:31:21+00:00",
    "sender_name": "GeorgeKan",
    "text": "красить будем"
  },
  {
    "id": 96437,
    "date": "2025-10-02 16:31:16+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Ну хотя бы красить будем?"
  },
  {
    "id": 96436,
    "date": "2025-10-02 16:31:11+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Почему"
  },
  {
    "id": 96434,
    "date": "2025-10-02 16:28:55+00:00",
    "sender_name": "GeorgeKan",
    "text": "но на пасху яйцами бится не будем"
  },
  {
    "id": 96433,
    "date": "2025-10-02 16:28:38+00:00",
    "sender_name": "GeorgeKan",
    "text": "будем вместе по воскресеньям в церковь ходить и молится"
  },
  {
    "id": 96432,
    "date": "2025-10-02 16:28:28+00:00",
    "sender_name": "GeorgeKan",
    "text": "то я тоже теперь верующий"
  },
  {
    "id": 96431,
    "date": "2025-10-02 16:28:23+00:00",
    "sender_name": "GeorgeKan",
    "text": "если таки е сть"
  },
  {
    "id": 96430,
    "date": "2025-10-02 16:28:14+00:00",
    "sender_name": "GeorgeKan",
    "text": "вот вот"
  },
  {
    "id": 96429,
    "date": "2025-10-02 16:28:13+00:00",
    "sender_name": "GeorgeKan",
    "text": "разве не для того что бы все в попке пальчиком ковырялись"
  },
  {
    "id": 96428,
    "date": "2025-10-02 16:27:57+00:00",
    "sender_name": "GeorgeKan",
