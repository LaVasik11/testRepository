[
  {
    "id": 97324,
    "date": "2025-10-06 19:54:45+00:00",
    "sender_name": "GeorgeKan",
    "text": "Не выходя"
  },
  {
    "id": 97323,
    "date": "2025-10-06 19:54:43+00:00",
    "sender_name": "GeorgeKan",
    "text": "Так и сидели"
  },
  {
    "id": 97322,
    "date": "2025-10-06 19:54:39+00:00",
    "sender_name": "GeorgeKan",
    "text": "Они заспавнились в комфортных условиях"
  },
  {
    "id": 97321,
    "date": "2025-10-06 19:54:31+00:00",
    "sender_name": "GeorgeKan",
    "text": "Они просто не пробывали че то делать"
  },
  {
    "id": 97320,
    "date": "2025-10-06 19:54:21+00:00",
    "sender_name": "GeorgeKan",
    "text": "Ну вот челы которые в 30 живут с родителями"
  },
  {
    "id": 97319,
    "date": "2025-10-06 19:54:11+00:00",
    "sender_name": "GeorgeKan",
    "text": "Просто легче будет все"
  },
  {
    "id": 97318,
    "date": "2025-10-06 19:54:06+00:00",
    "sender_name": "GeorgeKan",
    "text": "И чем рачньше опыт получишь тем пизже жить дальше"
  },
  {
    "id": 97317,
    "date": "2025-10-06 19:53:53+00:00",
    "sender_name": "GeorgeKan",
    "text": "Ну это факты что куда пизже жить чем сидеть в компах"
  },
  {
    "id": 97316,
    "date": "2025-10-06 19:53:02+00:00",
    "sender_name": "GeorgeKan",
    "text": "Буквально больше ничего не делая"
  },
  {
    "id": 97315,
    "date": "2025-10-06 19:52:56+00:00",
    "sender_name": "GeorgeKan",
    "text": "И щас сидит всю жизнь просто в доту играет"
  },
  {
    "id": 97314,
    "date": "2025-10-06 19:52:48+00:00",
    "sender_name": "GeorgeKan",
    "text": "Он когда то заработал"
  },
  {
    "id": 97313,
    "date": "2025-10-06 19:52:42+00:00",
    "sender_name": "GeorgeKan",
    "text": "Он же буквально пример того что ты описал"
  },
  {
    "id": 97312,
    "date": "2025-10-06 19:52:33+00:00",
    "sender_name": "GeorgeKan",
    "text": "Ну бля тот же андрей имершин"
  },
  {
    "id": 97311,
    "date": "2025-10-06 19:51:44+00:00",
    "sender_name": "GeorgeKan",
    "text": "Ну не такие тераны на родителях юыли"
  },
  {
    "id": 97310,
    "date": "2025-10-06 19:51:39+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Окей"
  },
  {
    "id": 97309,
    "date": "2025-10-06 19:51:31+00:00",
    "sender_name": "GeorgeKan",
    "text": "И расскажу историю с ним связаную"
  },
  {
    "id": 97308,
    "date": "2025-10-06 19:51:28+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "???"
  },
  {
    "id": 97307,
    "date": "2025-10-06 19:51:27+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "«Сергеев месяц без секса»"
  },
  {
    "id": 97306,
    "date": "2025-10-06 19:51:23+00:00",
    "sender_name": "GeorgeKan",
    "text": "Ща твое гс послушаю"
  },
  {
    "id": 97305,
    "date": "2025-10-06 19:51:18+00:00",
    "sender_name": "GeorgeKan",
    "text": "Этот чел вообще лютый"
  },
  {
    "id": 97304,
    "date": "2025-10-06 19:51:12+00:00",
    "sender_name": "GeorgeKan",
    "text": "Ток родители наказывали"
  },
  {
    "id": 97303,
    "date": "2025-10-06 19:51:05+00:00",
    "sender_name": "GeorgeKan",
    "text": "Хуйли все пиздюки"
  },
  {
    "id": 97302,
    "date": "2025-10-06 19:51:02+00:00",
    "sender_name": "GeorgeKan",
    "text": "Только учет"
  },
  {
    "id": 97301,
    "date": "2025-10-06 19:50:55+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Их прост на учет поставили и всё? Или наказали как ещё"
  },
  {
    "id": 97300,
    "date": "2025-10-06 19:50:39+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Ебать"
  },
  {
    "id": 97299,
    "date": "2025-10-06 19:50:37+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Хахахаха"
  },
  {
    "id": 97298,
    "date": "2025-10-06 19:50:21+00:00",
    "sender_name": "GeorgeKan",
    "text": "Легенда"
  },
  {
    "id": 97297,
    "date": "2025-10-06 19:50:20+00:00",
    "sender_name": "GeorgeKan",
    "text": "А сам поехал в мусарню"
  },
  {
    "id": 97296,
    "date": "2025-10-06 19:50:15+00:00",
    "sender_name": "GeorgeKan",
    "text": "Даже когда менты заберали он нам оставил лут"
  },
  {
    "id": 97295,
    "date": "2025-10-06 19:49:56+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Можно не слушать"
  },
  {
    "id": 97294,
    "date": "2025-10-06 19:49:55+00:00",
    "sender_name": "GeorgeKan",
    "text": "Чел не пассанул и до последнего не отдавал лут"
  },
  {
    "id": 97293,
    "date": "2025-10-06 19:49:47+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Я просто в унисон думал"
  },
  {
    "id": 97292,
    "date": "2025-10-06 19:49:43+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Читаю пока твое"
  },
  {
    "id": 97291,
    "date": "2025-10-06 19:49:40+00:00",
    "sender_name": "GeorgeKan",
    "text": "А там энергетики"
  },
  {
    "id": 97290,
    "date": "2025-10-06 19:49:38+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Без шуток"
  },
  {
    "id": 97289,
    "date": "2025-10-06 19:49:37+00:00",
    "sender_name": "GeorgeKan",
    "text": "Мы смотрим сменку"
  },
  {
    "id": 97288,
    "date": "2025-10-06 19:49:37+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Можно не слушать"
  },
  {
    "id": 97287,
    "date": "2025-10-06 19:49:31+00:00",
    "sender_name": "GeorgeKan",
    "text": "Ну кароче их увезли"
  },
  {
    "id": 97285,
    "date": "2025-10-06 19:49:26+00:00",
    "sender_name": "GeorgeKan",
    "text": "Странный мув какой то"
  },
  {
    "id": 97284,
    "date": "2025-10-06 19:49:19+00:00",
    "sender_name": "GeorgeKan",
    "text": "Сказал сто бы домой занесли"
  },
  {
    "id": 97283,
    "date": "2025-10-06 19:49:14+00:00",
    "sender_name": "GeorgeKan",
    "text": "И один из самых отбитых когда его уводили сменку нам передал"
  },
  {
    "id": 97282,
    "date": "2025-10-06 19:48:52+00:00",
    "sender_name": "GeorgeKan",
    "text": "И всех по одному просто пакуют"
  },
  {
    "id": 97281,
    "date": "2025-10-06 19:48:42+00:00",
    "sender_name": "GeorgeKan",
    "text": "И вот приезжают тачки мусорские"
  },
  {
    "id": 97280,
    "date": "2025-10-06 19:48:26+00:00",
    "sender_name": "GeorgeKan",
    "text": "Кенты кружки присылали с подсобки"
  },
  {
    "id": 97279,
    "date": "2025-10-06 19:48:18+00:00",
    "sender_name": "GeorgeKan",
    "text": "Забрали все что налутали"
  },
  {
    "id": 97278,
    "date": "2025-10-06 19:48:09+00:00",
    "sender_name": "GeorgeKan",
    "text": "И около часа там всех держали ждали ментов"
  },
  {
    "id": 97277,
    "date": "2025-10-06 19:47:56+00:00",
    "sender_name": "GeorgeKan",
    "text": "И потом его и остальных уводят в подсобку"
  },
  {
    "id": 97276,
    "date": "2025-10-06 19:47:42+00:00",
    "sender_name": "GeorgeKan",
    "text": "Выхрдит чел какой то и просто толкает его"
  },
  {
    "id": 97275,
    "date": "2025-10-06 19:47:35+00:00",
    "sender_name": "GeorgeKan",
    "text": "И вот первый кент уже на выходе с магаза"
  },
  {
    "id": 97274,
    "date": "2025-10-06 19:47:25+00:00",
    "sender_name": "GeorgeKan",
    "text": "Кенты пошли некоторые"
  }
]