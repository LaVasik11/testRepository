    "id": 103508,
    "date": "2025-10-20 22:27:50+00:00",
    "sender_name": "GeorgeKan",
    "text": "Тимофей"
  },
  {
    "id": 103507,
    "date": "2025-10-20 22:27:48+00:00",
    "sender_name": "GeorgeKan",
    "text": "Кот не продолжает жить"
