    "id": 103550,
    "date": "2025-10-20 22:31:58+00:00",
    "sender_name": "GeorgeKan",
    "text": "Но ты не знаешь"
  },
  {
    "id": 103549,
    "date": "2025-10-20 22:31:55+00:00",
    "sender_name": "GeorgeKan",
    "text": "Случилось это"
