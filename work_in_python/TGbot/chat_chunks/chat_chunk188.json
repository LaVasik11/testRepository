    "date": "2025-10-20 22:32:07+00:00",
    "sender_name": "GeorgeKan",
    "text": "Атом распался"
  },
  {
    "id": 103551,
    "date": "2025-10-20 22:32:04+00:00",
    "sender_name": "GeorgeKan",
    "text": "У тебя нету информации об этом"
  },
