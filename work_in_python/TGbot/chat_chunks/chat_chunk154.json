  {
    "id": 18942,
    "date": "2025-05-17 18:25:42+00:00",
    "sender_name": "GeorgeKan",
    "text": "или ты знаешь приём питона"
  },
  {
    "id": 18940,
    "date": "2025-05-17 18:25:37+00:00",
    "sender_name": "GeorgeKan",
    "text": "а мне лень"
