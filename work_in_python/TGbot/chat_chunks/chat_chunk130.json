  {
    "id": 91308,
    "date": "2025-09-23 20:49:38+00:00",
    "sender_name": "GeorgeKan",
    "text": "Даже фулл забитые"
  },
  {
    "id": 91307,
    "date": "2025-09-23 20:49:33+00:00",
    "sender_name": "GeorgeKan",
    "text": "Та все ровно челы сводят"
