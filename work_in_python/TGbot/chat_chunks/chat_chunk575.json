[
  {
    "id": 85851,
    "date": "2025-09-21 21:20:14+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "На Кротов гнать"
  },
  {
    "id": 85850,
    "date": "2025-09-21 21:20:12+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "ты базар фильтруй"
  },
  {
    "id": 85849,
    "date": "2025-09-21 21:20:10+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "ХАХХАА ЭЛРА"
  },
  {
    "id": 85848,
    "date": "2025-09-21 21:20:07+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "ХАХХАХАХ"
  },
  {
    "id": 85847,
    "date": "2025-09-21 21:20:05+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Ну ты на крот"
  },
  {
    "id": 85846,
    "date": "2025-09-21 21:19:58+00:00",
    "sender_name": "GeorgeKan",
    "text": "Крот же просто крыса подземная"
  },
  {
    "id": 85845,
    "date": "2025-09-21 21:19:50+00:00",
    "sender_name": "GeorgeKan",
    "text": "А крот че"
  },
  {
    "id": 85844,
    "date": "2025-09-21 21:19:47+00:00",
    "sender_name": "GeorgeKan",
    "text": "У них лапки смешные"
  },
  {
    "id": 85843,
    "date": "2025-09-21 21:19:41+00:00",
    "sender_name": "GeorgeKan",
    "text": "Всякую хуйню делают"
  },
  {
    "id": 85842,
    "date": "2025-09-21 21:19:34+00:00",
    "sender_name": "GeorgeKan",
    "text": "Играются смешно"
  },
  {
    "id": 85841,
    "date": "2025-09-21 21:19:29+00:00",
    "sender_name": "GeorgeKan",
    "text": "Еноты смешные пушистые"
  },
  {
    "id": 85840,
    "date": "2025-09-21 21:19:23+00:00",
    "sender_name": "GeorgeKan",
    "text": "Не, крот совсем другое"
  },
  {
    "id": 85839,
    "date": "2025-09-21 21:18:51+00:00",
    "sender_name": "GeorgeKan",
    "text": "Крутые еноты"
  },
  {
    "id": 85838,
    "date": "2025-09-21 21:18:42+00:00",
    "sender_name": "GeorgeKan",
    "text": "Нуда"
  },
  {
    "id": 85837,
    "date": "2025-09-21 21:18:35+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Это как крота поймать нахуй и его как питомца держать"
  },
  {
    "id": 85836,
    "date": "2025-09-21 21:18:20+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Их кто то как питомцев держит"
  },
  {
    "id": 85835,
    "date": "2025-09-21 21:18:15+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Они же вредители"
  },
  {
    "id": 85834,
    "date": "2025-09-21 21:18:10+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "А нахуя"
  },
  {
    "id": 85833,
    "date": "2025-09-21 21:17:45+00:00",
    "sender_name": "GeorgeKan",
    "text": "Вообще все"
  },
  {
    "id": 85832,
    "date": "2025-09-21 21:17:42+00:00",
    "sender_name": "GeorgeKan",
    "text": "Гладил"
  },
  {
    "id": 85831,
    "date": "2025-09-21 21:17:39+00:00",
    "sender_name": "GeorgeKan",
    "text": "Буквально каждый проходящий подходил спрашивал"
  },
  {
    "id": 85830,
    "date": "2025-09-21 21:17:28+00:00",
    "sender_name": "GeorgeKan",
    "text": "И все вахуе прохожие с енота"
  },
  {
    "id": 85829,
    "date": "2025-09-21 21:17:23+00:00",
    "sender_name": "GeorgeKan",
    "text": "Зато смешной"
  },
  {
    "id": 85828,
    "date": "2025-09-21 21:17:16+00:00",
    "sender_name": "GeorgeKan",
    "text": "Ебланчик"
  },
  {
    "id": 85827,
    "date": "2025-09-21 21:17:13+00:00",
    "sender_name": "GeorgeKan",
    "text": "Просто в лапы берет смотря в другую сторону"
  },
  {
    "id": 85826,
    "date": "2025-09-21 21:17:05+00:00",
    "sender_name": "GeorgeKan",
    "text": "И даже не смотрит на этл"
  },
  {
    "id": 85825,
    "date": "2025-09-21 21:17:01+00:00",
    "sender_name": "GeorgeKan",
    "text": "Подбирает в лапы вообще все что лежит"
  },
  {
    "id": 85824,
    "date": "2025-09-21 21:16:52+00:00",
    "sender_name": "GeorgeKan",
    "text": "Заборы"
  },
  {
    "id": 85823,
    "date": "2025-09-21 21:16:50+00:00",
    "sender_name": "GeorgeKan",
    "text": "Деревья"
  },
  {
    "id": 85822,
    "date": "2025-09-21 21:16:48+00:00",
    "sender_name": "GeorgeKan",
    "text": "Которая лазиет по всем вертикальным поверхносям"
  },
  {
    "id": 85821,
    "date": "2025-09-21 21:16:32+00:00",
    "sender_name": "GeorgeKan",
    "text": "Представь выгуливать собаку"
  },
  {
    "id": 85820,
    "date": "2025-09-21 21:16:26+00:00",
    "sender_name": "GeorgeKan",
    "text": "Та еще заеба"
  },
  {
    "id": 85819,
    "date": "2025-09-21 21:16:21+00:00",
    "sender_name": "GeorgeKan",
    "text": "Я помню енота выгуливал"
  },
  {
    "id": 85818,
    "date": "2025-09-21 21:16:06+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Потому надо кастрировать"
  },
  {
    "id": 85817,
    "date": "2025-09-21 21:16:03+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Тоже ужасно"
  },
  {
    "id": 85816,
    "date": "2025-09-21 21:16:01+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "И они орать начинают"
  },
  {
    "id": 85815,
    "date": "2025-09-21 21:15:59+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Если не кастрировать то тяночку либо кунчика хочется"
  },
  {
    "id": 85814,
    "date": "2025-09-21 21:15:47+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Ну как и в короче"
  },
  {
    "id": 85813,
    "date": "2025-09-21 21:15:45+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Он просто живет срет ссыт и спит"
  },
  {
    "id": 85812,
    "date": "2025-09-21 21:15:39+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Они в выгуле как собаки не нуждается"
  },
  {
    "id": 85811,
    "date": "2025-09-21 21:15:34+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Ну кто то выгуливает а по сути нахуй не надо"
  },
  {
    "id": 85810,
    "date": "2025-09-21 21:15:25+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Кстати наверное можно коту или кошке даже имя не давать а к звуку привязать? Они же на определенную хуйню просто ассоциацию выстраивают. Тип у них имя со жрачкой и лаской ассоциируются и потому подходят. По сути если уметь свистеть и просто с котенка свистеть на него он будет это за ассоциацию считать и теперь его имя буквально свист как звук"
  },
  {
    "id": 85809,
    "date": "2025-09-21 21:15:01+00:00",
    "sender_name": "GeorgeKan",
    "text": "Че с ними вообще делать"
  },
  {
    "id": 85808,
    "date": "2025-09-21 21:14:56+00:00",
    "sender_name": "GeorgeKan",
    "text": "У меня никогда небыло кота"
  },
  {
    "id": 85807,
    "date": "2025-09-21 21:14:51+00:00",
    "sender_name": "GeorgeKan",
    "text": "А с котами вообще надо гулять?"
  },
  {
    "id": 85806,
    "date": "2025-09-21 21:14:28+00:00",
    "sender_name": "GeorgeKan",
    "text": "Звать его"
  },
  {
    "id": 85805,
    "date": "2025-09-21 21:14:27+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Хахахаах ну да"
  },
  {
    "id": 85804,
    "date": "2025-09-21 21:14:27+00:00",
    "sender_name": "GeorgeKan",
    "text": "Мли когда гуляешь с нис"
  },
  {
    "id": 85803,
    "date": "2025-09-21 21:14:22+00:00",
    "sender_name": "GeorgeKan",
    "text": "Особено коту"
  },
  {
    "id": 85802,
    "date": "2025-09-21 21:13:58+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Хотя было бы смешно"
  },
  {
    "id": 85801,
    "date": "2025-09-21 21:13:55+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Мне не дали"
  },
  {
    "id": 85800,
    "date": "2025-09-21 21:13:53+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Почему то назвать кота Гитлер или Петушара"
  },
  {
    "id": 85799,
    "date": "2025-09-21 21:13:36+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Это в том числе"
  },
  {
    "id": 85798,
    "date": "2025-09-21 21:13:31+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Хахаахах"
  },
  {
    "id": 85797,
    "date": "2025-09-21 21:13:29+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Остальные вроде не я называл"
  },
  {
    "id": 85796,
    "date": "2025-09-21 21:13:27+00:00",
    "sender_name": "GeorgeKan",
    "text": "А я думал замки сменила"
  },
  {
    "id": 85795,
    "date": "2025-09-21 21:13:25+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Том, Вася"
  },
  {
    "id": 85794,
    "date": "2025-09-21 21:13:23+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Мои названцы это"
  },
  {
    "id": 85793,
    "date": "2025-09-21 21:13:20+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Я вроде почти всем имена раздал"
  },
  {
    "id": 85792,
    "date": "2025-09-21 21:13:13+00:00",
    "sender_name": "GeorgeKan",
    "text": "Том"
  },
  {
    "id": 85791,
    "date": "2025-09-21 21:13:12+00:00",
    "sender_name": "GeorgeKan",
    "text": "Крутой кот"
  },
  {
    "id": 85790,
    "date": "2025-09-21 21:13:12+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Мама стала ремонт делать"
  },
  {
    "id": 85789,
    "date": "2025-09-21 21:13:10+00:00",
    "sender_name": "GeorgeKan",
    "text": "Ихихи"
  },
  {
    "id": 85788,
    "date": "2025-09-21 21:13:09+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Я как уехал"
  },
  {
    "id": 85787,
    "date": "2025-09-21 21:13:07+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Его том зовут"
  },
  {
    "id": 85786,
    "date": "2025-09-21 21:13:03+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Хаха смотрите кот"
  },
  {
    "id": 85784,
    "date": "2025-09-21 21:12:56+00:00",
    "sender_name": "GeorgeKan",
    "text": "Я снова бездельник"
  },
  {
    "id": 85783,
    "date": "2025-09-21 21:12:54+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Слава богу"
  },
  {
    "id": 85782,
    "date": "2025-09-21 21:12:47+00:00",
    "sender_name": "GeorgeKan",
    "text": "Фридом"
  },
  {
    "id": 85781,
    "date": "2025-09-21 21:12:45+00:00",
    "sender_name": "GeorgeKan",
    "text": "Ладно похуй"
  },
  {
    "id": 85779,
    "date": "2025-09-21 21:10:16+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Тоже так считаю."
  },
  {
    "id": 85777,
    "date": "2025-09-21 21:09:57+00:00",
    "sender_name": "GeorgeKan",
    "text": "Давно пора было отбросить всё это ребячиство и шуточки и стать полноценным взрослым человеком."
  },
  {
    "id": 85776,
    "date": "2025-09-21 21:09:04+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Настало время повзрослеть, кто будет против. Самое время."
  },
  {
    "id": 85775,
    "date": "2025-09-21 21:08:55+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Не могу не вставить две копейки дабы объявить о том что сама концепция подобной тематики может показаться нудной, однако я настаиваю на том, что только слабый к снятию розовых очков человек воспротивится и заявит, что ему это не по душе."
  },
  {
    "id": 85772,
    "date": "2025-09-21 21:06:51+00:00",
    "sender_name": "GeorgeKan",
    "text": "Что тут нет места шуткам"
  },
  {
    "id": 85771,
    "date": "2025-09-21 21:06:46+00:00",
    "sender_name": "GeorgeKan",
    "text": "Что бы все понимали"
  },
  {
    "id": 85770,
    "date": "2025-09-21 21:06:42+00:00",
    "sender_name": "GeorgeKan",
    "text": "Прям мего серьездное"
  },
  {
    "id": 85769,
    "date": "2025-09-21 21:06:38+00:00",
    "sender_name": "GeorgeKan",
    "text": "И название"
  },
  {
    "id": 85768,
    "date": "2025-09-21 21:06:36+00:00",
    "sender_name": "GeorgeKan",
    "text": "Поставь че то серьездное на аву"
  },
  {
    "id": 85767,
    "date": "2025-09-21 21:06:31+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Мы уже не дети"
  },
  {
    "id": 85766,
    "date": "2025-09-21 21:06:29+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Шутки оставим в прошлом"
  },
  {
    "id": 85765,
    "date": "2025-09-21 21:06:29+00:00",
    "sender_name": "GeorgeKan",
    "text": "Да"
  },
  {
    "id": 85764,
    "date": "2025-09-21 21:06:26+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Отныне это серьезный чат"
  },
  {
    "id": 85763,
    "date": "2025-09-21 21:06:22+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Все"
  },
  {
    "id": 85762,
    "date": "2025-09-21 21:06:21+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "В том числе"
  },
  {
    "id": 85761,
    "date": "2025-09-21 21:05:57+00:00",
    "sender_name": "GeorgeKan",
    "text": "Я серьездный человек"
  },
  {
    "id": 85760,
    "date": "2025-09-21 21:05:53+00:00",
    "sender_name": "GeorgeKan",
    "text": "Я запрещаю смешно шутить в моём присудствие"
  },
  {
    "id": 85759,
    "date": "2025-09-21 21:05:36+00:00",
    "sender_name": "GeorgeKan",
    "text": "Смешно шутить это моя работа"
  },
  {
    "id": 85758,
    "date": "2025-09-21 21:05:30+00:00",
    "sender_name": "GeorgeKan",
    "text": "Ээ пахуевали эти бабы"
  },
  {
    "id": 85757,
    "date": "2025-09-21 21:05:00+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Больше не проживу"
  },
  {
    "id": 85756,
    "date": "2025-09-21 21:04:57+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "До 22"
  },
  {
    "id": 85753,
    "date": "2025-09-21 21:04:36+00:00",
    "sender_name": "GeorgeKan",
    "text": "Ты не переоценивай себя"
  },
  {
    "id": 85752,
    "date": "2025-09-21 21:04:31+00:00",
    "sender_name": "GeorgeKan",
    "text": "Лет до 30"
  },
  {
    "id": 85750,
    "date": "2025-09-21 21:02:13+00:00",
    "sender_name": "GeorgeKan",
    "text": "Стесняшка"
  },
  {
    "id": 85749,
    "date": "2025-09-21 21:02:11+00:00",
    "sender_name": "GeorgeKan",
    "text": "Он раньчше не всегда в дсе разговаривал"
  },
  {
    "id": 85748,
    "date": "2025-09-21 21:01:56+00:00",
    "sender_name": "GeorgeKan",
    "text": "Скромняга"
  },
  {
    "id": 85747,
    "date": "2025-09-21 21:01:51+00:00",
    "sender_name": "GeorgeKan",
    "text": "Может даже больше чем с сеней"
  },
  {
    "id": 85746,
    "date": "2025-09-21 21:01:49+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Почему он ваще ниче не рассказывает из жизни"
  },
  {
    "id": 85745,
    "date": "2025-09-21 21:01:44+00:00",
    "sender_name": "GeorgeKan",
    "text": "А я с ним 3 года знаком"
  },
  {
    "id": 85744,
    "date": "2025-09-21 21:01:39+00:00",
    "sender_name": "GeorgeKan",
    "text": "Ну так дело в том что я примернно та кже"
  },
  {
    "id": 85743,
    "date": "2025-09-21 21:01:39+00:00",
    "sender_name": "oppionme",
    "text": "Никита во сколько ле т ты понял"
  },
  {
    "id": 85742,
    "date": "2025-09-21 21:01:25+00:00",
    "sender_name": "GeorgeKan",
    "text": "Всмысле нельзя в 45лет усыновить 7млетнюю девочку"
  },
  {
    "id": 85741,
    "date": "2025-09-21 21:01:05+00:00",
    "sender_name": "GeorgeKan",
    "text": "Что я могу его усыновить и пиздить"
  },
  {
    "id": 85740,
    "date": "2025-09-21 21:01:02+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "В смысле нельзя в 18 лет усыновить 17-ти летнюю сисястую девочку вы че ахуели"
  },
  {
    "id": 85739,
