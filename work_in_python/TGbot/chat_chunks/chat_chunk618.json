[
  {
    "id": 105449,
    "date": "2025-10-24 21:10:46+00:00",
    "sender_name": "GeorgeKan",
    "text": "я его прям аж зауважал тогда"
  },
  {
    "id": 105448,
    "date": "2025-10-24 21:10:40+00:00",
    "sender_name": "GeorgeKan",
    "text": "крутой чел"
  },
  {
    "id": 105447,
    "date": "2025-10-24 21:10:38+00:00",
    "sender_name": "GeorgeKan",
    "text": "прям запонилось"
  },
  {
    "id": 105446,
    "date": "2025-10-24 21:10:35+00:00",
    "sender_name": "GeorgeKan",
    "text": "говорит мне скзаали вас пиздят че случилось"
  },
  {
    "id": 105445,
    "date": "2025-10-24 21:10:28+00:00",
    "sender_name": "GeorgeKan",
    "text": "он прям бежал влетать помогать"
  },
  {
    "id": 105444,
    "date": "2025-10-24 21:10:23+00:00",
    "sender_name": "GeorgeKan",
    "text": "один из нех прям рельно крутой чел"
  },
  {
    "id": 105443,
    "date": "2025-10-24 21:10:14+00:00",
    "sender_name": "GeorgeKan",
    "text": "сьебался звать на помощ кентов что рядом где то гуляли"
  },
  {
    "id": 105442,
    "date": "2025-10-24 21:10:06+00:00",
    "sender_name": "GeorgeKan",
    "text": "и этот чел что сьебал от нас уже с подмогой подлетает"
  },
  {
    "id": 105441,
    "date": "2025-10-24 21:10:03+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Че дальше"
  },
  {
    "id": 105440,
    "date": "2025-10-24 21:10:01+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Хааха таак"
  },
  {
    "id": 105439,
    "date": "2025-10-24 21:09:57+00:00",
    "sender_name": "GeorgeKan",
    "text": "идем дальше"
  },
  {
    "id": 105438,
    "date": "2025-10-24 21:09:55+00:00",
    "sender_name": "GeorgeKan",
    "text": "мы с челами побазарили и разошлись на мирном"
  },
  {
    "id": 105437,
    "date": "2025-10-24 21:09:43+00:00",
    "sender_name": "GeorgeKan",
    "text": "он куда то сьёбывает"
  },
  {
    "id": 105436,
    "date": "2025-10-24 21:09:39+00:00",
    "sender_name": "GeorgeKan",
    "text": "кароче пока мы с кентом стоим базарим"
  },
  {
    "id": 105435,
    "date": "2025-10-24 21:09:33+00:00",
    "sender_name": "GeorgeKan",
    "text": "точно не стал бы влетать в файт с нами"
  },
  {
    "id": 105434,
    "date": "2025-10-24 21:09:27+00:00",
    "sender_name": "GeorgeKan",
    "text": "челик ну явно не боевой"
  },
  {
    "id": 105433,
    "date": "2025-10-24 21:09:21+00:00",
    "sender_name": "GeorgeKan",
    "text": "не мейн туса"
  },
  {
    "id": 105432,
    "date": "2025-10-24 21:09:18+00:00",
    "sender_name": "GeorgeKan",
    "text": "1 такой"
  },
  {
    "id": 105431,
    "date": "2025-10-24 21:09:16+00:00",
    "sender_name": "GeorgeKan",
    "text": "нас всего 3 чела было"
  },
  {
    "id": 105430,
    "date": "2025-10-24 21:09:07+00:00",
    "sender_name": "GeorgeKan",
    "text": "типо хуйли ты нож крутишь"
  },
  {
    "id": 105429,
    "date": "2025-10-24 21:09:04+00:00",
    "sender_name": "GeorgeKan",
    "text": "и до нас челы доебались"
  },
  {
    "id": 105428,
    "date": "2025-10-24 21:08:58+00:00",
    "sender_name": "GeorgeKan",
    "text": "ща сделаю"
  },
  {
    "id": 105427,
    "date": "2025-10-24 21:08:52+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Жора сделай сигну на имя Тимофей"
  },
  {
    "id": 105426,
    "date": "2025-10-24 21:08:51+00:00",
    "sender_name": "GeorgeKan",
    "text": "помню просто с кентами идём по городу крутим нож бабочку который нашли на заброшке"
  },
  {
    "id": 105425,
    "date": "2025-10-24 21:08:46+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Это сигна?"
  },
  {
    "id": 105424,
    "date": "2025-10-24 21:08:18+00:00",
    "sender_name": "GeorgeKan",
    "text": "и делал всякое"
  },
  {
    "id": 105423,
    "date": "2025-10-24 21:08:15+00:00",
    "sender_name": "GeorgeKan",
    "text": "котоырй шлялся по дворам"
  },
  {
    "id": 105422,
    "date": "2025-10-24 21:08:11+00:00",
    "sender_name": "GeorgeKan",
    "text": "и при этом быть отбитым панком пиздюком"
  },
  {
    "id": 105421,
    "date": "2025-10-24 21:08:04+00:00",
    "sender_name": "GeorgeKan",
    "text": "ходить на секции всякие"
  },
  {
    "id": 105420,
    "date": "2025-10-24 21:08:00+00:00",
    "sender_name": "GeorgeKan",
    "text": "я вахуе как я детстве успивал норм учится"
  },
  {
    "id": 105418,
    "date": "2025-10-24 21:06:53+00:00",
    "sender_name": "GeorgeKan",
    "text": "будто самому решить было легче"
  },
  {
    "id": 105417,
    "date": "2025-10-24 21:06:47+00:00",
    "sender_name": "GeorgeKan",
    "text": "но задача не из лёгких была"
  },
  {
    "id": 105416,
    "date": "2025-10-24 21:06:43+00:00",
    "sender_name": "GeorgeKan",
    "text": "да будто бывало что списывали"
  },
  {
    "id": 105415,
    "date": "2025-10-24 21:06:34+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "С таким почерком"
  },
  {
    "id": 105414,
    "date": "2025-10-24 21:06:30+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Хахаха Жора я правильно понимаю что у тебя никто и никогда не списывал?"
  },
  {
    "id": 105413,
    "date": "2025-10-24 21:06:19+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Пж"
  },
  {
    "id": 105412,
    "date": "2025-10-24 21:06:17+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Дай списать"
  },
  {
    "id": 105411,
    "date": "2025-10-24 21:04:03+00:00",
    "sender_name": "GeorgeKan",
    "text": "цифры"
  },
  {
    "id": 105410,
    "date": "2025-10-24 21:04:01+00:00",
    "sender_name": "GeorgeKan",
    "text": "тут причем пример"
  },
  {
    "id": 105409,
    "date": "2025-10-24 21:03:57+00:00",
    "sender_name": "GeorgeKan",
    "text": "откуда у тебя моя тетрадь по матиматике"
  },
  {
    "id": 105407,
    "date": "2025-10-24 21:03:23+00:00",
    "sender_name": "GeorgeKan",
    "text": "юзлес"
  },
  {
    "id": 105406,
    "date": "2025-10-24 21:03:20+00:00",
    "sender_name": "GeorgeKan",
    "text": "хз"
  },
  {
    "id": 105405,
    "date": "2025-10-24 21:03:19+00:00",
    "sender_name": "GeorgeKan",
    "text": "но прям что бы красиво делать это"
  },
  {
    "id": 105404,
    "date": "2025-10-24 21:03:11+00:00",
    "sender_name": "GeorgeKan",
    "text": "писать уметь надо"
  },
  {
    "id": 105403,
    "date": "2025-10-24 21:03:08+00:00",
    "sender_name": "GeorgeKan",
    "text": "ну ладно"
  },
  {
    "id": 105402,
    "date": "2025-10-24 21:03:01+00:00",
    "sender_name": "GeorgeKan",
    "text": "я хз где щас в мире нужно уметь писать от руки"
  },
  {
    "id": 105401,
    "date": "2025-10-24 21:02:46+00:00",
    "sender_name": "GeorgeKan",
    "text": "все"
  },
  {
    "id": 105400,
    "date": "2025-10-24 21:02:46+00:00",
    "sender_name": "GeorgeKan",
    "text": "это пару символов придрчоеной подписи"
  },
  {
    "id": 105399,
    "date": "2025-10-24 21:02:38+00:00",
    "sender_name": "GeorgeKan",
    "text": "только подписи в банках всяких и все"
  },
  {
    "id": 105398,
    "date": "2025-10-24 21:02:32+00:00",
    "sender_name": "GeorgeKan",
    "text": "ну я буквально вообще не использую письмо от руки"
  }
]