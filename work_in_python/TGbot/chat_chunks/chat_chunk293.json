  {
    "id": 97404,
    "date": "2025-10-07 12:28:18+00:00",
    "sender_name": "GeorgeKan",
    "text": "Ну да"
  },
  {
    "id": 97403,
    "date": "2025-10-07 12:27:44+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Богом"
  },
  {
    "id": 97402,
    "date": "2025-10-07 12:27:43+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Что он поцелован"
  },
  {
    "id": 97401,
    "date": "2025-10-07 12:27:36+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "В имени бога же нет"
  },
  {
    "id": 97400,
    "date": "2025-10-07 12:27:28+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "В том числе и бог?"
  },
  {
    "id": 97399,
    "date": "2025-10-07 12:23:36+00:00",
    "sender_name": "GeorgeKan",
    "text": "А остальные обсоски"
  },
  {
    "id": 97398,
    "date": "2025-10-07 12:23:31+00:00",
    "sender_name": "GeorgeKan",
    "text": "Просто какая то часть слово означающая что ты богом поциловон и вообще самый крутой"
  },
  {
    "id": 97397,
    "date": "2025-10-07 12:23:11+00:00",
    "sender_name": "GeorgeKan",
    "text": "Ну такая же хуйня как со святослав борислав и другие славы"
