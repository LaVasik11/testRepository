  {
    "id": 97384,
    "date": "2025-10-07 11:24:59+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Пораньше отпустили"
  },
  {
    "id": 97383,
    "date": "2025-10-07 11:24:56+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Домой иду"
  },
  {
    "id": 97382,
    "date": "2025-10-07 11:15:30+00:00",
    "sender_name": "gaysesg",
    "text": "Чёт они не рады тебе"
  },
  {
    "id": 97378,
    "date": "2025-10-07 11:03:11+00:00",
    "sender_name": "GeorgeKan",
    "text": "Это первая"
  },
  {
    "id": 97376,
    "date": "2025-10-07 11:02:32+00:00",
    "sender_name": "GeorgeKan",
    "text": "Время обзора на всех собак которые у меня есть"
