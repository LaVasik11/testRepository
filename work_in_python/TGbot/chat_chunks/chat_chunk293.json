  {
    "id": 97465,
    "date": "2025-10-07 12:44:54+00:00",
    "sender_name": "GeorgeKan",
    "text": "Это не бесконечная темнота"
  },
  {
    "id": 97464,
    "date": "2025-10-07 12:44:48+00:00",
    "sender_name": "GeorgeKan",
    "text": "Нихуч не будет"
  },
  {
    "id": 97463,
    "date": "2025-10-07 12:44:45+00:00",
    "sender_name": "GeorgeKan",
    "text": "После смерти мозг не работает и все"
  },
  {
    "id": 97461,
    "date": "2025-10-07 12:44:40+00:00",
    "sender_name": "GeorgeKan",
    "text": "Нету никакой ебаной души"
  },
  {
    "id": 97460,
    "date": "2025-10-07 12:44:36+00:00",
    "sender_name": "GeorgeKan",
    "text": "Все что ты думаешь чувствуешь и мыслишь это буквально раьота твоего мозга"
  },
  {
    "id": 97459,
    "date": "2025-10-07 12:44:17+00:00",
    "sender_name": "GeorgeKan",
    "text": "Будто одному мне очевидно это"
  },
  {
    "id": 97458,
    "date": "2025-10-07 12:44:05+00:00",
    "sender_name": "GeorgeKan",
    "text": "Я это доказал"
  },
  {
    "id": 97457,
    "date": "2025-10-07 12:44:03+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Это сатана"
