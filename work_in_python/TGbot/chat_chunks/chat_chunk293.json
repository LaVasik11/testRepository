  {
    "id": 97419,
    "date": "2025-10-07 12:33:40+00:00",
    "sender_name": "GeorgeKan",
    "text": "Потом оьезательно молятся"
  },
  {
    "id": 97418,
    "date": "2025-10-07 12:33:35+00:00",
    "sender_name": "GeorgeKan",
    "text": "Сначало хуярят людей"
