  {
    "id": 97452,
    "date": "2025-10-07 12:43:48+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Да"
  },
  {
    "id": 97451,
    "date": "2025-10-07 12:43:47+00:00",
    "sender_name": "QUETIAPINUM_BOY",
