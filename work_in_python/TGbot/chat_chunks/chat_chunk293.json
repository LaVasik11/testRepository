  {
    "id": 97454,
    "date": "2025-10-07 12:43:52+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Также было"
  },
  {
    "id": 97453,
    "date": "2025-10-07 12:43:49+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Жиза"
