  {
    "id": 97387,
    "date": "2025-10-07 11:32:21+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "За Жору исправил"
  },
  {
    "id": 97386,
    "date": "2025-10-07 11:25:04+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "*опустили"
  },
  {
    "id": 97385,
    "date": "2025-10-07 11:24:59+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Ура"
