    "id": 97471,
    "date": "2025-10-07 12:46:11+00:00",
    "sender_name": "oppionme",
    "text": "ну да"
  },
  {
    "id": 97470,
    "date": "2025-10-07 12:46:01+00:00",
    "sender_name": "GeorgeKan",
    "text": "Нет у меня прям наводящие вопросы"
