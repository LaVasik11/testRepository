[
  {
    "id": 113856,
    "date": "2025-11-07 18:19:25+00:00",
    "sender_name": "GeorgeKan",
    "text": "Ноувей"
  },
  {
    "id": 113855,
    "date": "2025-11-07 18:19:24+00:00",
    "sender_name": "GeorgeKan",
    "text": "Ну это точно хуйня"
  },
  {
    "id": 113854,
    "date": "2025-11-07 18:19:11+00:00",
    "sender_name": "GeorgeKan",
    "text": "Жду версию от нетфликса где гендальф белый будет гендальфом чёрным"
  },
  {
    "id": 113853,
    "date": "2025-11-07 18:18:57+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Жора когда просмотр форсаж все части начиная с первой"
  },
  {
    "id": 113852,
    "date": "2025-11-07 18:18:40+00:00",
    "sender_name": "GeorgeKan",
    "text": "И всё"
  },
  {
    "id": 113851,
    "date": "2025-11-07 18:18:39+00:00",
    "sender_name": "GeorgeKan",
    "text": "Ну типо приколько эльфы стилька раздают"
  },
  {
    "id": 113850,
    "date": "2025-11-07 18:18:23+00:00",
    "sender_name": "GeorgeKan",
    "text": "Нихуя интересного"
  },
  {
    "id": 113849,
    "date": "2025-11-07 18:18:20+00:00",
    "sender_name": "GeorgeKan",
    "text": "По 3 части в каждой"
  },
  {
    "id": 113848,
    "date": "2025-11-07 18:18:13+00:00",
    "sender_name": "GeorgeKan",
    "text": "И то и то дрисня полная"
  },
  {
    "id": 113847,
    "date": "2025-11-07 18:18:01+00:00",
    "sender_name": "GeorgeKan",
    "text": "Ну и хоббит поганый"
  },
  {
    "id": 113846,
    "date": "2025-11-07 18:17:52+00:00",
    "sender_name": "GeorgeKan",
    "text": "Властелин колец?"
  },
  {
    "id": 113845,
    "date": "2025-11-07 18:17:45+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Как у азазина"
  },
  {
    "id": 113844,
    "date": "2025-11-07 18:17:43+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Вот это идеал"
  },
  {
    "id": 113843,
    "date": "2025-11-07 18:17:40+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Фильм на две три части"
  },
  {
    "id": 113842,
    "date": "2025-11-07 18:17:38+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Нужно че то посередине"
  },
  {
    "id": 113841,
    "date": "2025-11-07 18:17:33+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "В фильме не хватает в сериале слишком затянуто и непонятно нахуя"
  },
  {
    "id": 113840,
    "date": "2025-11-07 18:17:14+00:00",
    "sender_name": "GeorgeKan",
    "text": "Потом они решаются"
  },
  {
    "id": 113839,
    "date": "2025-11-07 18:17:10+00:00",
    "sender_name": "GeorgeKan",
    "text": "По этому у него появляются траблы"
  },
  {
    "id": 113838,
    "date": "2025-11-07 18:17:05+00:00",
    "sender_name": "GeorgeKan",
    "text": "Гг врёт потому что ну сказать правду это для лохов"
  },
  {
    "id": 113837,
    "date": "2025-11-07 18:17:03+00:00",
    "sender_name": "gaysesg",
    "text": "жора ты поганец"
  },
  {
    "id": 113836,
    "date": "2025-11-07 18:16:56+00:00",
    "sender_name": "GeorgeKan",
    "text": "Обсолютно всегда и везде одна и та же схема"
  },
  {
    "id": 113835,
    "date": "2025-11-07 18:16:36+00:00",
    "sender_name": "GeorgeKan",
    "text": "1 и те жи мувы"
  },
  {
    "id": 113834,
    "date": "2025-11-07 18:16:32+00:00",
    "sender_name": "GeorgeKan",
    "text": "У них всегда 1 и тот же сюжет"
  },
  {
    "id": 113833,
    "date": "2025-11-07 18:16:27+00:00",
    "sender_name": "gaysesg",
    "text": "а в 2 просто лох"
  },
  {
    "id": 113832,
    "date": "2025-11-07 18:16:25+00:00",
    "sender_name": "GeorgeKan",
    "text": "Все сериалы тупое говно"
  },
  {
    "id": 113831,
    "date": "2025-11-07 18:16:24+00:00",
    "sender_name": "gaysesg",
    "text": "в 1 сезоне легенда"
  },
  {
    "id": 113830,
    "date": "2025-11-07 18:16:19+00:00",
    "sender_name": "gaysesg",
    "text": "физрука просто тупым сделали"
  },
  {
    "id": 113829,
    "date": "2025-11-07 18:16:13+00:00",
    "sender_name": "gaysesg",
    "text": "сука ну почему сериал такого говна"
  },
  {
    "id": 113828,
    "date": "2025-11-07 18:13:54+00:00",
    "sender_name": "GeorgeKan",
    "text": "Для девушки можно просто атмосерное имечко и всё"
  },
  {
    "id": 113827,
    "date": "2025-11-07 18:13:35+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "А для девушки"
  },
  {
    "id": 113826,
    "date": "2025-11-07 18:13:16+00:00",
    "sender_name": "GeorgeKan",
    "text": "Доя мамы точно бери с продресью"
  },
  {
    "id": 113825,
    "date": "2025-11-07 18:12:55+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Да"
  },
  {
    "id": 113824,
    "date": "2025-11-07 18:12:22+00:00",
    "sender_name": "GeorgeKan",
    "text": "Подарок на др мамы выбираешь?"
  },
  {
    "id": 113823,
    "date": "2025-11-07 18:12:20+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Поэтому микрон заглушенныц всегда"
  },
  {
    "id": 113822,
    "date": "2025-11-07 18:12:15+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Ты то разбираешься"
  },
  {
    "id": 113821,
    "date": "2025-11-07 18:12:07+00:00",
    "sender_name": "GeorgeKan",
    "text": "И как это всё работает"
  },
  {
    "id": 113820,
    "date": "2025-11-07 18:12:02+00:00",
    "sender_name": "GeorgeKan",
    "text": "Там куча инфы про заварвариватель"
  },
  {
    "id": 113819,
    "date": "2025-11-07 18:11:54+00:00",
    "sender_name": "GeorgeKan",
    "text": "На 12 атмосфер"
  },
  {
    "id": 113818,
    "date": "2025-11-07 18:11:51+00:00",
    "sender_name": "GeorgeKan",
    "text": "Он записывал гайд"
  },
  {
    "id": 113817,
    "date": "2025-11-07 18:11:47+00:00",
    "sender_name": "GeorgeKan",
    "text": "Ты просто быдло необразованое"
  },
  {
    "id": 113816,
    "date": "2025-11-07 18:11:38+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Каким нахуй образом он знает как он посрет"
  },
  {
    "id": 113815,
    "date": "2025-11-07 18:11:26+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Насрать просто и насрать с продрисью"
  },
  {
    "id": 113814,
    "date": "2025-11-07 18:11:17+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "И там есть опция нахуй"
  },
  {
    "id": 113813,
    "date": "2025-11-07 18:11:14+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Потому что я щас почитал прайс на поздравление"
  },
  {
    "id": 113812,
    "date": "2025-11-07 18:11:08+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Есть подозрения что в хорьков пиздит насчет пердежа и какулек"
  },
  {
    "id": 113811,
    "date": "2025-11-07 18:02:05+00:00",
    "sender_name": "GeorgeKan",
    "text": "Можешь слово \"физрук\" сокращать до \"я\""
  },
  {
    "id": 113810,
    "date": "2025-11-07 18:01:36+00:00",
    "sender_name": "GeorgeKan",
    "text": "Ты"
  },
  {
    "id": 113809,
    "date": "2025-11-07 17:55:16+00:00",
    "sender_name": "gaysesg",
    "text": "физрук"
  },
  {
    "id": 113807,
    "date": "2025-11-07 17:25:14+00:00",
    "sender_name": "GeorgeKan",
    "text": "Ты слей свинка"
  },
  {
    "id": 113806,
    "date": "2025-11-07 17:25:09+00:00",
    "sender_name": "GeorgeKan",
    "text": "Никита это ты"
  }
]