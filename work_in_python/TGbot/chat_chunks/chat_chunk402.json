[
  {
    "id": 98400,
    "date": "2025-10-08 15:49:03+00:00",
    "sender_name": "GeorgeKan",
    "text": "Сказал бы владельцу"
  },
  {
    "id": 98399,
    "date": "2025-10-08 15:48:58+00:00",
    "sender_name": "GeorgeKan",
    "text": "А нахуя ты из своего то заплатил"
  },
  {
    "id": 98398,
    "date": "2025-10-08 15:48:50+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "За 20 дней"
  },
  {
    "id": 98397,
    "date": "2025-10-08 15:48:46+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Выжрать столько жлектриаетсва"
  },
  {
    "id": 98396,
    "date": "2025-10-08 15:48:38+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Потому что я не мог на одном холодильнике"
  },
  {
    "id": 98395,
    "date": "2025-10-08 15:48:33+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Жду пока мне владелец хаты кинет обратно"
  },
  {
    "id": 98394,
    "date": "2025-10-08 15:48:29+00:00",
    "sender_name": "GeorgeKan",
    "text": "А на самом деле это глубокий смысл"
  },
  {
    "id": 98393,
    "date": "2025-10-08 15:48:28+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Здравствуйте"
  },
  {
    "id": 98392,
    "date": "2025-10-08 15:48:26+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "За электроэнергию нахуй"
  },
  {
    "id": 98390,
    "date": "2025-10-08 15:48:21+00:00",
    "sender_name": "GeorgeKan",
    "text": "И то что это быдло тупое видит хуи"
  },
  {
    "id": 98389,
    "date": "2025-10-08 15:48:06+00:00",
    "sender_name": "GeorgeKan",
    "text": "В оправданиее скажи что ты художник"
  },
  {
    "id": 98386,
    "date": "2025-10-08 15:47:59+00:00",
    "sender_name": "GeorgeKan",
    "text": "Разрисуй подъезд хуями"
  },
  {
    "id": 98384,
    "date": "2025-10-08 15:47:45+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Правда че мне делать ваще хуй знает"
  },
  {
    "id": 98383,
    "date": "2025-10-08 15:47:41+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Очень эстетично"
  },
  {
    "id": 98382,
    "date": "2025-10-08 15:47:38+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Пойду курить и пить кофе на балкон"
  },
  {
    "id": 98381,
    "date": "2025-10-08 15:47:30+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Не знал что можно заебаться в рисовании лол"
  },
  {
    "id": 98380,
    "date": "2025-10-08 15:47:23+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "После черепа вообще нихуя нарисовать не могу"
  },
  {
    "id": 98379,
    "date": "2025-10-08 15:47:20+00:00",
    "sender_name": "GeorgeKan",
    "text": "Полюбому уебки на жури не справедливо засудили"
  },
  {
    "id": 98378,
    "date": "2025-10-08 15:46:42+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Вылетел("
  },
  {
    "id": 98377,
    "date": "2025-10-08 15:46:41+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "За узбеков"
  },
  {
    "id": 98376,
    "date": "2025-10-08 15:46:39+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Я в прошлой серии"
  },
  {
    "id": 98375,
    "date": "2025-10-08 15:43:19+00:00",
    "sender_name": "GeorgeKan",
    "text": "Ты какую страну представлял?"
  },
  {
    "id": 98374,
    "date": "2025-10-08 15:42:21+00:00",
    "sender_name": "GeorgeKan",
    "text": "Что такое ростикс"
  },
  {
    "id": 98373,
    "date": "2025-10-08 15:39:15+00:00",
    "sender_name": "oppionme",
    "text": "немного пиздят а так нет"
  },
  {
    "id": 98372,
    "date": "2025-10-08 15:33:16+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Не шугают на районе?"
