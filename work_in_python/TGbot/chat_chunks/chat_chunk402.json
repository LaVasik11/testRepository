  {
    "id": 98371,
    "date": "2025-10-08 15:33:13+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Тебя кучерявого"
  },
  {
    "id": 98370,
    "date": "2025-10-08 15:28:46+00:00",
    "sender_name": "oppionme",
    "text": "в КФС нет"
