    "text": "я бы мог"
  },
  {
    "id": 54023,
    "date": "2025-08-14 21:14:04+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "хахаха"
  },
  {
    "id": 54022,
    "date": "2025-08-14 21:14:00+00:00",
    "sender_name": "GeorgeKan",
    "text": "Под одеялко"
  },
  {
    "id": 54021,
    "date": "2025-08-14 21:13:56+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "я не ебу схуяли там тепло"
  },
  {
    "id": 54020,
    "date": "2025-08-14 21:13:56+00:00",
    "sender_name": "GeorgeKan",
    "text": "Ну лег бы с ним"
  },
  {
    "id": 54019,
    "date": "2025-08-14 21:13:51+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "под пузом хранит же"
  },
  {
    "id": 54018,
    "date": "2025-08-14 21:13:48+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "наверное"
  },
  {
    "id": 54017,
    "date": "2025-08-14 21:13:46+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "ну типо мать"
  },
  {
    "id": 54016,
    "date": "2025-08-14 21:13:42+00:00",
    "sender_name": "GeorgeKan",
    "text": "А как в гнезде то тепло"
  },
  {
    "id": 54015,
    "date": "2025-08-14 21:13:40+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "даже обогреватель не помог бы"
  },
  {
    "id": 54014,
    "date": "2025-08-14 21:13:36+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "ясен хуй в бытовухе их нет"
  },
  {
    "id": 54013,
    "date": "2025-08-14 21:13:32+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "потому что для этого нужны особенные лампы"
  },
  {
    "id": 54012,
    "date": "2025-08-14 21:13:29+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "но я никак сука не мог ему сделать тепло"
  },
  {
    "id": 54011,
    "date": "2025-08-14 21:13:25+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "скорее всего от холода"
  },
  {
    "id": 54010,
    "date": "2025-08-14 21:13:23+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "банально птенец сдох михаил"
  },
  {
    "id": 54009,
    "date": "2025-08-14 21:13:20+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Я ХУЙ ЗНАЕТ ПОЧЕМУ"
  },
  {
    "id": 54008,
    "date": "2025-08-14 21:13:17+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "кроме щенка и котенка"
  },
  {
    "id": 54007,
    "date": "2025-08-14 21:13:13+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "дохнет"
  },
  {
    "id": 54006,
    "date": "2025-08-14 21:13:12+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "подобранное в попытках выкармливать"
  },
  {
    "id": 54005,
    "date": "2025-08-14 21:13:05+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "в целом любое животное"
  },
  {
    "id": 54004,
    "date": "2025-08-14 21:12:21+00:00",
    "sender_name": "GeorgeKan",
    "text": "В жару"
  },
  {
    "id": 54003,
    "date": "2025-08-14 21:12:18+00:00",
    "sender_name": "GeorgeKan",
    "text": "Мне бабушка не сказала что хуйня идея крота оставить  вбанке"
  },
  {
    "id": 54002,
    "date": "2025-08-14 21:12:06+00:00",
    "sender_name": "GeorgeKan",
    "text": "Никто меня не остановил"
  },
  {
    "id": 54001,
    "date": "2025-08-14 21:11:38+00:00",
    "sender_name": "GeorgeKan",
    "text": "С тех пор я кротов больше в банки не сажал"
  },
  {
    "id": 54000,
    "date": "2025-08-14 21:11:30+00:00",
    "sender_name": "GeorgeKan",
    "text": "А он умер :("
  },
  {
    "id": 53999,
    "date": "2025-08-14 21:11:23+00:00",
    "sender_name": "GeorgeKan",
    "text": "Я хотел его до приезда мамы отсавить и показать"
  },
  {
    "id": 53998,
    "date": "2025-08-14 21:11:05+00:00",
    "sender_name": "GeorgeKan",
    "text": "Пиздатый опыт"
  },
  {
    "id": 53997,
    "date": "2025-08-14 21:11:01+00:00",
    "sender_name": "GeorgeKan",
    "text": "На месяц"
  },
  {
    "id": 53996,
    "date": "2025-08-14 21:10:59+00:00",
    "sender_name": "GeorgeKan",
    "text": "По любому ребенка своего вдеревню хоть раз отправлю"
  },
  {
    "id": 53995,
    "date": "2025-08-14 21:10:34+00:00",
    "sender_name": "GeorgeKan",
    "text": "Крота помню поймал в банку посадил"
  },
  {
    "id": 53994,
    "date": "2025-08-14 21:10:27+00:00",
    "sender_name": "GeorgeKan",
    "text": "И я ходил делал десятки разных оружий"
  },
  {
    "id": 53993,
    "date": "2025-08-14 21:10:18+00:00",
    "sender_name": "GeorgeKan",
    "text": "Типо просто мне дали пилу и нож"
  },
  {
    "id": 53992,
    "date": "2025-08-14 21:10:06+00:00",
    "sender_name": "GeorgeKan",
    "text": "И из деревьев оружия делал"
  },
  {
    "id": 53991,
    "date": "2025-08-14 21:10:00+00:00",
    "sender_name": "GeorgeKan",
    "text": "Я и яму огромнуб капал"
  },
  {
    "id": 53990,
    "date": "2025-08-14 21:09:55+00:00",
    "sender_name": "GeorgeKan",
    "text": "Будто это прям супер сильно развивает"
  },
  {
    "id": 53989,
    "date": "2025-08-14 21:09:46+00:00",
    "sender_name": "GeorgeKan",
    "text": "Я там столько всего делал"
  },
  {
    "id": 53988,
    "date": "2025-08-14 21:09:41+00:00",
    "sender_name": "GeorgeKan",
    "text": "Без телефонов"
  },
  {
    "id": 53987,
    "date": "2025-08-14 21:09:38+00:00",
    "sender_name": "GeorgeKan",
    "text": "Будто реально круто детей в деревню так то отпровлять"
  },
  {
    "id": 53986,
    "date": "2025-08-14 21:09:16+00:00",
    "sender_name": "GeorgeKan",
    "text": "Но я в детсве ебашил к ней в деревнб выкапывать огромнуб яму для погреба"
  },
  {
    "id": 53985,
    "date": "2025-08-14 21:09:01+00:00",
    "sender_name": "GeorgeKan",
    "text": "Ей ничего не мешало"
  },
  {
    "id": 53984,
    "date": "2025-08-14 21:08:56+00:00",
    "sender_name": "GeorgeKan",
    "text": "Хотя могла в городе жить"
  },
  {
    "id": 53983,
    "date": "2025-08-14 21:08:43+00:00",
    "sender_name": "GeorgeKan",
    "text": "У меня бабушка переехала с горада в деревню жить"
  },
  {
    "id": 53982,
    "date": "2025-08-14 21:08:30+00:00",
    "sender_name": "GeorgeKan",
    "text": "Нахуй оно надо"
  },
  {
    "id": 53981,
    "date": "2025-08-14 21:08:26+00:00",
    "sender_name": "GeorgeKan",
    "text": "Жить точно нет"
  },
  {
    "id": 53980,
    "date": "2025-08-14 21:08:21+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "НЕ ЖИТЬ НАХУЙ"
  },
  {
    "id": 53979,
    "date": "2025-08-14 21:08:20+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "АХХА"
  },
  {
    "id": 53978,
    "date": "2025-08-14 21:08:20+00:00",
    "sender_name": "GeorgeKan",
    "text": "Полезно"
  },
  {
    "id": 53977,
    "date": "2025-08-14 21:08:20+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "но"
  },
  {
    "id": 53976,
    "date": "2025-08-14 21:08:19+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "отдохнуть то можно"
  }
