  {
    "id": 94484,
    "date": "2025-09-29 17:44:04+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Да"
  },
  {
    "id": 94483,
    "date": "2025-09-29 17:43:35+00:00",
