  {
    "id": 94471,
    "date": "2025-09-29 17:42:03+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Если холодно"
  },
  {
    "id": 94470,
    "date": "2025-09-29 17:42:01+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Так то норм темка так одеваться"
