  {
    "id": 94519,
    "date": "2025-09-29 17:50:45+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "И посмеются"
  },
  {
    "id": 94518,
    "date": "2025-09-29 17:50:44+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Но велик шанс что меня без спроса запостят в пинтерест"
