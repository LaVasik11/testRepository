  {
    "id": 94481,
    "date": "2025-09-29 17:42:51+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "А затем водолазку"
  },
  {
    "id": 94480,
    "date": "2025-09-29 17:42:47+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Надеть футболку"
