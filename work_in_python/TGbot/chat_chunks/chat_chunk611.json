[
  {
    "id": 97273,
    "date": "2025-10-06 19:47:16+00:00",
    "sender_name": "GeorgeKan",
    "text": "Не пошел на делюгу"
  },
  {
    "id": 97272,
    "date": "2025-10-06 19:47:12+00:00",
    "sender_name": "GeorgeKan",
    "text": "Кароче в тот день я просто на выходе с магаза стоял"
  },
  {
    "id": 97271,
    "date": "2025-10-06 19:46:47+00:00",
    "sender_name": "GeorgeKan",
    "text": "До момента пока не поймали всех"
  },
  {
    "id": 97270,
    "date": "2025-10-06 19:46:37+00:00",
    "sender_name": "GeorgeKan",
    "text": "Самые пиздатые времена"
  },
  {
    "id": 97269,
    "date": "2025-10-06 19:46:15+00:00",
    "sender_name": "GeorgeKan",
    "text": "Меня кенты под руки взяли и тащили"
  },
  {
    "id": 97268,
    "date": "2025-10-06 19:46:06+00:00",
    "sender_name": "GeorgeKan",
    "text": "Голова кружилась шо пиздец"
  },
  {
    "id": 97267,
    "date": "2025-10-06 19:45:58+00:00",
    "sender_name": "GeorgeKan",
    "text": "Въебало знатно"
  },
  {
    "id": 97266,
    "date": "2025-10-06 19:45:49+00:00",
    "sender_name": "GeorgeKan",
    "text": "Чет типо 45 мг было"
  },
  {
    "id": 97265,
    "date": "2025-10-06 19:45:36+00:00",
    "sender_name": "GeorgeKan",
    "text": "Тогда я вроде перввй раз снюс закинул"
  },
  {
    "id": 97264,
    "date": "2025-10-06 19:45:28+00:00",
    "sender_name": "GeorgeKan",
    "text": "Ходили вобщем по разным магазам и лутались раз в определенное время"
  },
  {
    "id": 97263,
    "date": "2025-10-06 19:44:59+00:00",
    "sender_name": "GeorgeKan",
    "text": "По приколу"
  },
  {
    "id": 97262,
    "date": "2025-10-06 19:44:58+00:00",
    "sender_name": "GeorgeKan",
    "text": "Их было так много что мы просто открывали энергетики и на пол выливали"
  },
  {
    "id": 97261,
    "date": "2025-10-06 19:44:45+00:00",
    "sender_name": "GeorgeKan",
    "text": "Просто хавали столько вкусностей сколько хотели"
  },
  {
    "id": 97260,
    "date": "2025-10-06 19:44:36+00:00",
    "sender_name": "GeorgeKan",
    "text": "Энергетики киндары пингви прингалсы"
  },
  {
    "id": 97259,
    "date": "2025-10-06 19:44:30+00:00",
    "sender_name": "GeorgeKan",
    "text": "И спокойно просто набивали рюкзаки чем кайф"
  },
  {
    "id": 97258,
    "date": "2025-10-06 19:44:19+00:00",
    "sender_name": "GeorgeKan",
    "text": "Да"
  },
  {
    "id": 97257,
    "date": "2025-10-06 19:44:18+00:00",
    "sender_name": "GeorgeKan",
    "text": "Там он знал магазы без камер"
  },
  {
    "id": 97256,
    "date": "2025-10-06 19:44:15+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Вчера было?"
  },
  {
    "id": 97255,
    "date": "2025-10-06 19:44:11+00:00",
    "sender_name": "GeorgeKan",
    "text": "Мы на поезде гоняли в другой город к кенту"
  },
  {
    "id": 97254,
    "date": "2025-10-06 19:43:53+00:00",
    "sender_name": "GeorgeKan",
    "text": "Самые крутые времена были"
  },
  {
    "id": 97253,
    "date": "2025-10-06 19:43:45+00:00",
    "sender_name": "GeorgeKan",
    "text": "Я так и не рассказал как мы с кентами в магазинах воровали"
  },
  {
    "id": 97252,
    "date": "2025-10-06 19:43:23+00:00",
    "sender_name": "GeorgeKan",
    "text": "Ну хуйли в детстве то можно было делать че угодно безнаказанео"
  },
  {
    "id": 97251,
    "date": "2025-10-06 19:43:08+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "И че"
  },
  {
    "id": 97250,
    "date": "2025-10-06 19:43:01+00:00",
    "sender_name": "GeorgeKan",
    "text": "Так ты в сего на год ровесник мой"
  },
  {
    "id": 97249,
    "date": "2025-10-06 19:42:44+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Старше"
  },
  {
    "id": 97248,
    "date": "2025-10-06 19:42:31+00:00",
    "sender_name": "GeorgeKan",
    "text": "Так ты всего на год младше"
  },
  {
    "id": 97247,
    "date": "2025-10-06 19:41:54+00:00",
    "sender_name": "GeorgeKan",
    "text": "Мб все к чему он стремился это играть в гарисмод"
  },
  {
    "id": 97246,
    "date": "2025-10-06 19:41:41+00:00",
    "sender_name": "GeorgeKan",
    "text": "Чел кайфует"
  },
  {
    "id": 97244,
    "date": "2025-10-06 19:40:32+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Да"
  },
  {
    "id": 97242,
    "date": "2025-10-06 19:37:36+00:00",
    "sender_name": "GeorgeKan",
    "text": "В не зависимости что ты скажешь"
  },
  {
    "id": 97241,
    "date": "2025-10-06 19:37:29+00:00",
    "sender_name": "GeorgeKan",
    "text": "А никита если даже и прочитай то ответит кроликом с часами"
  },
  {
    "id": 97240,
    "date": "2025-10-06 19:37:17+00:00",
    "sender_name": "GeorgeKan",
    "text": "Арсений все ровно скипает половину сообщений"
  },
  {
    "id": 97239,
    "date": "2025-10-06 19:36:41+00:00",
    "sender_name": "GeorgeKan",
    "text": "Давай"
  },
  {
    "id": 97238,
    "date": "2025-10-06 19:36:34+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Обсужу момент один"
  },
  {
    "id": 97237,
    "date": "2025-10-06 19:36:31+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Тут могу записать гс с пердежом если надо"
  },
  {
    "id": 97236,
    "date": "2025-10-06 19:36:29+00:00",
    "sender_name": "GeorgeKan",
    "text": "Столько всего интерестного можно делать"
  },
  {
    "id": 97235,
    "date": "2025-10-06 19:36:19+00:00",
    "sender_name": "GeorgeKan",
    "text": "А не пытаться кайфануть нихуя не делая"
  },
  {
    "id": 97234,
    "date": "2025-10-06 19:36:12+00:00",
    "sender_name": "GeorgeKan",
    "text": "Если хочется испытать эффект попробуйте выйти из комнаты"
  },
  {
    "id": 97233,
    "date": "2025-10-06 19:35:32+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Жить такова"
  },
  {
    "id": 97231,
    "date": "2025-10-06 19:34:16+00:00",
    "sender_name": "GeorgeKan",
    "text": "Жить жосткая брат"
  },
  {
    "id": 97230,
    "date": "2025-10-06 19:34:04+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Жоско брат"
  },
  {
    "id": 97229,
    "date": "2025-10-06 19:33:59+00:00",
    "sender_name": "GeorgeKan",
    "text": "Другими словами формацевтику хавал"
  },
  {
    "id": 97228,
    "date": "2025-10-06 19:33:50+00:00",
    "sender_name": "GeorgeKan",
    "text": "Я пил таблетки, сосательные когда горло болело"
  },
  {
    "id": 97225,
    "date": "2025-10-06 19:30:07+00:00",
    "sender_name": "GeorgeKan",
    "text": "На все 40к на гидре бы закупился"
  },
  {
    "id": 97224,
    "date": "2025-10-06 19:29:57+00:00",
    "sender_name": "GeorgeKan",
    "text": "В тот же день"
  },
  {
    "id": 97223,
    "date": "2025-10-06 19:29:54+00:00",
    "sender_name": "GeorgeKan",
    "text": "Моментально"
  },
  {
    "id": 97222,
    "date": "2025-10-06 19:29:52+00:00",
    "sender_name": "GeorgeKan",
    "text": "Сразу же"
  },
  {
    "id": 97221,
    "date": "2025-10-06 19:29:50+00:00",
    "sender_name": "GeorgeKan",
    "text": "Не пизди , сторчался бы"
  },
  {
    "id": 97220,
    "date": "2025-10-06 19:29:11+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Да"
  },
  {
    "id": 97218,
    "date": "2025-10-06 19:29:01+00:00",
    "sender_name": "GeorgeKan",
    "text": "И можешь че кайф делать"
  },
  {
    "id": 97217,
    "date": "2025-10-06 19:28:56+00:00",
    "sender_name": "GeorgeKan",
    "text": "Твоих деняг"
  },
  {
    "id": 97216,
    "date": "2025-10-06 19:28:53+00:00",
    "sender_name": "GeorgeKan",
    "text": "И вот у тебя тыщ 30 просто на руках"
  },
  {
    "id": 97215,
    "date": "2025-10-06 19:28:46+00:00",
    "sender_name": "GeorgeKan",
    "text": "Врятли же ты когда то такую сумму получал"
  },
  {
    "id": 97214,
    "date": "2025-10-06 19:28:38+00:00",
    "sender_name": "GeorgeKan",
    "text": "Мб другие ощущения были бы"
  },
  {
    "id": 97213,
    "date": "2025-10-06 19:28:26+00:00",
    "sender_name": "GeorgeKan",
    "text": "Забрал бы разом за месяц"
  },
  {
    "id": 97212,
    "date": "2025-10-06 19:28:00+00:00",
    "sender_name": "GeorgeKan",
    "text": "Ну ты не за месяц забрал"
  },
  {
    "id": 97211,
    "date": "2025-10-06 19:27:52+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Иди к 11 на 12 часовую смену"
  },
  {
    "id": 97210,
    "date": "2025-10-06 19:27:50+00:00",
    "sender_name": "GeorgeKan",
    "text": "И умереть в нищите  в 30 лет живя с мамой"
  },
  {
    "id": 97209,
    "date": "2025-10-06 19:27:40+00:00",
    "sender_name": "GeorgeKan",
    "text": "Такое желание дикое нахуй не возврощатся учится"
  },
  {
    "id": 97207,
    "date": "2025-10-06 19:27:26+00:00",
    "sender_name": "GeorgeKan",
    "text": "Бля щас дома лежу на большой кровати сытый"
  },
  {
    "id": 97206,
    "date": "2025-10-06 19:13:24+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Будьте людьми Пж"
  },
  {
    "id": 97205,
    "date": "2025-10-06 19:13:22+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Зачем срать ребят"
  },
  {
    "id": 97204,
    "date": "2025-10-06 19:13:18+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Это противно"
  },
  {
    "id": 97203,
    "date": "2025-10-06 19:13:16+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Я против сранья"
  },
  {
    "id": 97202,
    "date": "2025-10-06 19:13:14+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Я не сру"
  },
  {
    "id": 97201,
    "date": "2025-10-06 19:12:54+00:00",
    "sender_name": "GeorgeKan",
    "text": "Как ты срешь?"
  },
  {
    "id": 97200,
    "date": "2025-10-06 19:12:46+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Пищдатык"
  },
  {
    "id": 97199,
    "date": "2025-10-06 19:12:45+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Я фотки наделал"
  },
  {
    "id": 97198,
    "date": "2025-10-06 19:12:43+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Мне лень"
  },
  {
    "id": 97197,
    "date": "2025-10-06 19:12:25+00:00",
    "sender_name": "GeorgeKan",
    "text": "Ты так и не ответил про вопрос про то как какать"
  },
  {
    "id": 97196,
    "date": "2025-10-06 19:11:46+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Умом"
  },
  {
    "id": 97195,
    "date": "2025-10-06 19:07:05+00:00",
    "sender_name": "GeorgeKan",
    "text": "Лучше голодать"
  },
  {
    "id": 97194,
    "date": "2025-10-06 19:07:02+00:00",
    "sender_name": "GeorgeKan",
    "text": "Прям фу бля фу нахуй"
  },
  {
    "id": 97193,
    "date": "2025-10-06 19:06:57+00:00",
    "sender_name": "GeorgeKan",
    "text": "Выглядит прям ну фу"
  },
  {
    "id": 97192,
    "date": "2025-10-06 19:06:52+00:00",
    "sender_name": "GeorgeKan",
    "text": "И чет нет желания"
  },
  {
    "id": 97191,
    "date": "2025-10-06 19:06:49+00:00",
    "sender_name": "GeorgeKan",
    "text": "Не разу не пробовал консервы"
  },
  {
    "id": 97190,
    "date": "2025-10-06 19:06:28+00:00",
    "sender_name": "GeorgeKan",
    "text": "Нахуя съезжать от радителей"
  },
  {
    "id": 97189,
    "date": "2025-10-06 19:06:14+00:00",
    "sender_name": "GeorgeKan",
    "text": "Я щас домой приехал и с таким кайфом похавал макароны с мясом"
  },
  {
    "id": 97188,
    "date": "2025-10-06 19:03:20+00:00",
    "sender_name": "gaysesg",
    "text": "вот только доел"
  },
  {
    "id": 97187,
    "date": "2025-10-06 19:03:18+00:00",
    "sender_name": "gaysesg",
    "text": "и кайфуешь"
  },
  {
    "id": 97186,
    "date": "2025-10-06 19:03:14+00:00",
    "sender_name": "gaysesg",
    "text": "просто фарш в томатном соусе ебашишь с макаронами"
  },
  {
    "id": 97185,
    "date": "2025-10-06 19:03:05+00:00",
    "sender_name": "gaysesg",
    "text": "какая жидкость макарон"
  },
  {
    "id": 97184,
    "date": "2025-10-06 18:47:34+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Все сказал"
  },
  {
    "id": 97180,
    "date": "2025-10-06 18:40:13+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Там нету открывашки"
  },
  {
    "id": 97179,
    "date": "2025-10-06 18:36:08+00:00",
    "sender_name": "oppionme",
    "text": "а чё не руками"
  },
  {
    "id": 97178,
    "date": "2025-10-06 18:33:56+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Щас поем вкусно"
  },
  {
    "id": 97177,
    "date": "2025-10-06 18:33:54+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Заебался"
  },
  {
    "id": 97176,
    "date": "2025-10-06 18:33:53+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Консерву ножом открывал"
  },
  {
    "id": 97175,
    "date": "2025-10-06 18:33:44+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Фух"
  },
  {
    "id": 97174,
    "date": "2025-10-06 18:08:45+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Мне кажется"
  },
  {
    "id": 97173,
    "date": "2025-10-06 18:08:32+00:00",
    "sender_name": "QUETIAPINUM_BOY",
    "text": "Про мать лишне было"
  },
  {
    "id": 97172,
    "date": "2025-10-06 17:59:44+00:00",
    "sender_name": "GeorgeKan",
    "text": "Вообще нет различия между армянским и грузинским"
  },
  {
    "id": 97171,
    "date": "2025-10-06 17:59:43+00:00",
    "sender_name": "GeorgeKan",
    "text": "Тоже самое что я скидывал как твой брат близнец на рмянском с кем то пиздел"
  },
  {
    "id": 97170,
    "date": "2025-10-06 17:59:06+00:00",
    "sender_name": "GeorgeKan",
    "text": "Грузинская мафия"
  },
  {
    "id": 97169,
    "date": "2025-10-06 17:57:25+00:00",
    "sender_name": "oppionme",
    "text": "мафия чисто епта"
  },
  {
    "id": 97168,
    "date": "2025-10-06 17:57:21+00:00",
    "sender_name": "oppionme",
    "text": "че за головорезы блять общаются"
  },
  {
    "id": 97167,
    "date": "2025-10-06 17:52:48+00:00",
    "sender_name": "GeorgeKan",
    "text": "Это пожалуй единственное что он рассказал за этот год"
  },
  {
    "id": 97165,
    "date": "2025-10-06 17:49:18+00:00",
    "sender_name": "GeorgeKan",
    "text": "Если что тут инфы больше чем никита рассказал о себе за последний год"
  },
  {
    "id": 97164,
    "date": "2025-10-06 17:48:06+00:00",
    "sender_name": "GeorgeKan",
    "text": "А ты типо встаёшь ногами на толчек?"
  },
  {
    "id": 97162,
    "date": "2025-10-06 17:46:45+00:00",
    "sender_name": "GeorgeKan",
    "text": "Ладно"
  },
  {
    "id": 97161,
    "date": "2025-10-06 17:46:45+00:00",
    "sender_name": "GeorgeKan",
    "text": "Но нет это я его"
  },
  {
    "id": 97160,
    "date": "2025-10-06 17:46:45+00:00",
    "sender_name": "GeorgeKan",
    "text": "Что это просто ребёнок орет в поезде рядом"
  },
  {
    "id": 97159,
    "date": "2025-10-06 17:46:45+00:00",
    "sender_name": "GeorgeKan",
    "text": "Я понимаю возможно вы подумали"
  },
  {
    "id": 97158,
    "date": "2025-10-06 17:46:45+00:00",
    "sender_name": "GeorgeKan",
    "text": "Ребчта клянусь это не то самое"
  },
  {
    "id": 97157,
    "date": "2025-10-06 17:46:45+00:00",
    "sender_name": "GeorgeKan",
    "text": "Это совсем не то чем кажется"
  },
  {
    "id": 97156,
    "date": "2025-10-06 17:46:44+00:00",
    "sender_name": "GeorgeKan",
    "text": "Пупупу"
  },
  {
    "id": 97155,
    "date": "2025-10-06 17:46:44+00:00",
    "sender_name": "GeorgeKan",
    "text": "Да я чет тоже щас кружок пересоушал"
  },
  {
    "id": 97154,
